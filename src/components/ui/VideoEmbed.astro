---
/**
 * VideoEmbed — standard YouTube iframe embed.
 * Shows YouTube's native player UI (title, channel, watch-on-YouTube) before playback.
 */
interface Props {
  videoId: string;
  title?: string;
}

const { videoId, title = "Video" } = Astro.props;
---

<div class="aspect-video rounded-lg overflow-hidden bg-[var(--color-bg-secondary)]">
  <iframe
    src={`https://www.youtube.com/embed/${videoId}`}
    title={title}
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
    allowfullscreen
    loading="lazy"
    class="w-full h-full"
  ></iframe>
</div>
