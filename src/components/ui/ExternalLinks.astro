---
/**
 * ExternalLinks — renders game external links (itch, Steam, YouTube, GDrive, GitHub)
 * plus optional CTA button for docs.
 */
import type { GameProject } from "../../data/games";
import type { Lang } from "../../i18n/config";
import { ui } from "../../i18n";

interface Props {
  game: GameProject;
  lang: Lang;
}

const { game, lang } = Astro.props;

const links: { label: string; href: string; icon: string }[] = [];

if (game.links.itch) {
  links.push({ label: "itch.io", href: game.links.itch, icon: "itch" });
}
if (game.links.steam) {
  links.push({ label: "Steam", href: game.links.steam, icon: "steam" });
}
if (game.links.youtube) {
  links.push({ label: "YouTube", href: game.links.youtube, icon: "youtube" });
}
if (game.links.gdrive) {
  game.links.gdrive.forEach((url, i) => {
    links.push({
      label: `Google Drive${game.links.gdrive!.length > 1 ? ` ${i + 1}` : ""}`,
      href: url,
      icon: "gdrive",
    });
  });
}
if (game.links.github) {
  links.push({ label: "GitHub", href: game.links.github, icon: "github" });
}

// Docs CTA
let docsHref: string | null = null;
let docsLabel = "";
if (game.docsType === "tech-docs") {
  docsHref = lang === "en" ? `/en/docs/${game.slug}/` : `/docs/${game.slug}/`;
  docsLabel = ui("game.viewTechDocs", lang);
} else if (game.docsType === "key-features") {
  docsHref = lang === "en" ? `/en/docs/${game.slug}/` : `/docs/${game.slug}/`;
  docsLabel = ui("game.viewKeyFeatures", lang);
}
---

<div class="flex flex-wrap items-center gap-3 py-4">
  {/* Docs CTA */}
  {
    docsHref && (
      <a
        href={docsHref}
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white text-sm font-medium rounded-lg transition-colors"
      >
        {docsLabel}
      </a>
    )
  }

  {/* External Links */}
  {
    links.map(({ label, href }) => (
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-2 bg-[var(--color-bg-secondary)] hover:bg-[var(--color-bg-tertiary)] text-[var(--color-text-secondary)] hover:text-[var(--color-text)] text-sm rounded-lg border border-[var(--color-border)] transition-colors"
      >
        {label}
        <svg
          class="w-3 h-3"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
          />
        </svg>
      </a>
    ))
  }
</div>
