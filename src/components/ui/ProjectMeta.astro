---
/**
 * ProjectMeta — displays game metadata in a grid (Role, Engine, Platform, Team, Duration).
 */
import type { GameProject } from '../../data/games';
import type { Lang } from '../../i18n/config';
import { t, ui } from '../../i18n';

interface Props {
  game: GameProject;
  lang: Lang;
}

const { game, lang } = Astro.props;

const metaItems = [
  { label: ui('game.role', lang), value: t(game.meta.role, lang) },
  { label: ui('game.engine', lang), value: game.meta.engine },
  { label: ui('game.platform', lang), value: game.meta.platform },
  { label: ui('game.teamSize', lang), value: t(game.meta.teamSize, lang) },
  { label: ui('game.duration', lang), value: t(game.meta.duration, lang) },
];
---

<div class="grid grid-cols-2 md:grid-cols-3 gap-4 py-6">
  {metaItems.map(({ label, value }) => (
    <div class="space-y-1">
      <dt class="text-xs uppercase tracking-wider text-[#6b6b6b]">{label}</dt>
      <dd class="text-sm text-[#e0e0e0]">{value}</dd>
    </div>
  ))}
</div>
