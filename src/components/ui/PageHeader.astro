---
/**
 * PageHeader — shared page header for Other Works pages (Music, Photography, Graphic Design).
 * Centered title + English subtitle + bottom divider line.
 */
interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mb-16 pb-8 border-b border-[var(--color-border)] text-center">
  <h1 class="text-3xl md:text-4xl font-bold text-[var(--color-text)]">{title}</h1>
  <p class="mt-2 text-sm text-[var(--color-text-muted)]">{subtitle}</p>
</div>
