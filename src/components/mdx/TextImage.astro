---
/**
 * MDX layout: text block alongside a single image.
 * align="right" (default) → left text + right image
 * align="left" → left image + right text
 */
interface Props {
  image: string;
  alt?: string;
  align?: 'left' | 'right';
  caption?: string;
}

const { image, alt = '', align = 'right', caption } = Astro.props;
---

<div class={`not-prose my-8 flex flex-col gap-6 md:flex-row md:items-start ${align === 'left' ? 'md:flex-row-reverse' : ''}`}>
  <div class="flex-1 min-w-0">
    <slot />
  </div>
  <figure class="flex-shrink-0 w-full md:w-2/5">
    <img
      src={image}
      alt={alt}
      class="w-full rounded-lg object-cover"
      loading="lazy"
    />
    {caption && (
      <figcaption class="mt-2 text-xs text-center text-[var(--color-text-muted)]">
        {caption}
      </figcaption>
    )}
  </figure>
</div>
