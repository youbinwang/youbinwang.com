---
/**
 * HeroSection — full-width hero with background image, gradient overlay, and text.
 * Supports view transitions for smooth page changes.
 * Used on the homepage and optionally on section landing pages.
 */

interface Props {
  /** URL or path to background image */
  backgroundImage?: string;
  title: string;
  subtitle?: string;
  /** Full height hero (homepage) vs shorter banner */
  fullHeight?: boolean;
}

const { backgroundImage, title, subtitle, fullHeight = false } = Astro.props;
const heightClass = fullHeight ? 'min-h-[80vh]' : 'min-h-[40vh]';
---

<section
  class:list={[
    'relative w-full flex items-center justify-center overflow-hidden',
    heightClass,
  ]}
  transition:name="hero"
  transition:animate="fade"
>
  {/* Background Image */}
  {backgroundImage && (
    <div class="absolute inset-0">
      <img
        src={backgroundImage}
        alt=""
        class="w-full h-full object-cover"
        loading="eager"
      />
      {/* Multi-layer gradient for depth */}
      <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/50 to-[#111111]"></div>
    </div>
  )}

  {/* Fallback gradient background when no image */}
  {!backgroundImage && (
    <div class="absolute inset-0 bg-gradient-to-b from-[#1a1a1a] to-[#111111]"></div>
  )}

  {/* Content */}
  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight drop-shadow-lg">
      {title}
    </h1>
    {subtitle && (
      <p class="mt-4 text-base sm:text-lg md:text-xl text-[#c0c0c0] tracking-widest font-light">
        {subtitle}
      </p>
    )}
    <slot />
  </div>
</section>