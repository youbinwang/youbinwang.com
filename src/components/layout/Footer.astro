---
/**
 * Footer — two-column layout: name (left) + email & social icons (right).
 * Supports Light/Dark mode via CSS variables.
 */
import type { Lang } from "../../i18n/config";
import { getLocalizedPath } from "../../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer class="border-t border-[var(--color-border)] py-10">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">

    <!-- Left: Name -->
    <span class="text-xl font-bold text-[var(--color-text)] tracking-wide">
      Youbin Wang
    </span>

    <!-- Right: Email + Icons -->
    <div class="flex flex-col items-start sm:items-end gap-3">
      <a
        href="mailto:youbinwang1205@gmail.com"
        class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors underline underline-offset-4 decoration-[var(--color-border)] hover:decoration-[var(--color-border-strong)]"
      >
        youbinwang1205@gmail.com
      </a>

      <div class="flex items-center gap-4 text-[var(--color-text-muted)]">
        <!-- Docs -->
        <a
          href={getLocalizedPath("/docs/", lang)}
          class="hover:text-[var(--color-text)] transition-colors"
          aria-label="Docs"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 19.5A2.5 2.5 0 016.5 17H20" />
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z" />
          </svg>
        </a>
        <!-- GitHub -->
        <a
          href="https://github.com/youbinwang"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-[var(--color-text)] transition-colors"
          aria-label="GitHub"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
          </svg>
        </a>
        <!-- LinkedIn -->
        <a
          href="https://www.linkedin.com/in/youbinwang/"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-[var(--color-text)] transition-colors"
          aria-label="LinkedIn"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
        </a>
      </div>
    </div>

  </div>
</footer>
