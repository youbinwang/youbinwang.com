---
/**
 * Navbar — site-wide navigation with language switch, social icons, and mobile menu.
 * Transparent on hero pages, becomes opaque on scroll.
 * Supports Light/Dark mode via CSS variables.
 */
import type { Lang } from "../../i18n/config";
import { getLocalizedPath, ui, uiEN } from "../../i18n";
import MobileMenu from "./MobileMenu";

interface Props {
  lang: Lang;
  /** When true, navbar starts transparent over the hero */
  transparent?: boolean;
}

const { lang, transparent = false } = Astro.props;
const langLabel = lang === "en" ? "中文" : "EN";
const langSwitchPath =
  lang === "en"
    ? Astro.url.pathname.replace(/^\/en/, "") || "/"
    : `/en${Astro.url.pathname}`;

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === "/" || href === "/en/") {
    return currentPath === href;
  }
  return currentPath.startsWith(href);
}

const navItems = [
  { label: uiEN("nav.home"), href: getLocalizedPath("/", lang) },
  { label: uiEN("nav.games"), href: getLocalizedPath("/games/", lang) },
  { label: uiEN("nav.films"), href: getLocalizedPath("/films/", lang) },
];

const otherWorksItems = [
  { label: uiEN("nav.photography"), href: getLocalizedPath("/photography/", lang) },
  { label: uiEN("nav.graphicDesign"), href: getLocalizedPath("/graphic-design/", lang) },
  { label: uiEN("nav.music"), href: getLocalizedPath("/music/", lang) },
];

const aboutItem = {
  label: uiEN("nav.about"),
  href: getLocalizedPath("/about/", lang),
};

const isDocsActive = currentPath.startsWith('/docs/') || currentPath.startsWith('/en/docs/');
const isOtherWorksActive = !isDocsActive && otherWorksItems.some((item) => isActive(item.href));
const allNavItems = [...navItems, ...otherWorksItems, aboutItem];

/* Color classes based on transparent mode */
const textCls = transparent ? "text-white" : "text-[var(--color-text)]";
const textMutedCls = transparent ? "text-white/70 hover:text-white" : "text-[var(--color-text-muted)] hover:text-[var(--color-text)]";
const iconCls = transparent ? "text-white/70 hover:text-white hover:bg-white/10" : "text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface-hover)]";
const sepCls = transparent ? "bg-white/30" : "bg-[var(--color-border)]";
---

<nav
  id="main-nav"
  aria-label="Main navigation"
  class:list={[
    "fixed top-0 left-0 right-0 z-50 transition-all duration-300",
    transparent
      ? ""
      : "bg-[var(--color-surface-overlay)] backdrop-blur-md border-b border-[var(--color-border)]",
  ]}
  data-transparent={transparent ? "true" : "false"}
  style={transparent ? "--color-hamburger: white" : "--color-hamburger: var(--color-text)"}
  transition:animate="none"
>
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a
        href={getLocalizedPath("/", lang)}
        class:list={["nav-text font-bold text-xl tracking-wide hover:opacity-80 transition-all duration-300", textCls]}
        transition:name="logo"
      >
        Youbin Wang
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            data-navlink={item.href}
            class:list={[
              "nav-text px-3 py-2 text-sm transition-all duration-300 relative",
              isActive(item.href) ? textCls : textMutedCls,
            ]}
          >
            {item.label}
            {isActive(item.href) && (
              <span class="nav-active-bar absolute bottom-0 left-3 right-3 h-0.5 bg-[var(--color-accent)] rounded-full" />
            )}
          </a>
        ))}

        <!-- Other Works Dropdown -->
        <div class="relative group">
          <button
            data-otherworks
            class:list={[
              "nav-text border-0 bg-transparent cursor-pointer px-3 py-2 text-sm transition-all duration-300 flex items-center gap-1 relative",
              isOtherWorksActive ? textCls : textMutedCls,
            ]}
            aria-haspopup="true"
            aria-expanded="false"
          >
            {uiEN("nav.otherWorks")}
            <svg class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
            {isOtherWorksActive && (
              <span class="nav-active-bar absolute bottom-0 left-3 right-3 h-0.5 bg-[var(--color-accent)] rounded-full" />
            )}
          </button>
          <div class="absolute top-full left-1/2 -translate-x-1/2 mt-1 py-2 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-200 min-w-[180px]" role="menu">
            {otherWorksItems.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "block px-4 py-2.5 text-sm transition-colors",
                  isActive(item.href)
                    ? "text-[var(--color-text)] bg-[var(--color-accent-bg)]"
                    : "text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface-hover)]",
                ]}
                role="menuitem"
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>

        <a
          href={aboutItem.href}
          data-navlink={aboutItem.href}
          class:list={[
            "nav-text px-3 py-2 text-sm transition-all duration-300 relative",
            isActive(aboutItem.href) ? textCls : textMutedCls,
          ]}
        >
          {aboutItem.label}
          {isActive(aboutItem.href) && (
            <span class="nav-active-bar absolute bottom-0 left-3 right-3 h-0.5 bg-[var(--color-accent)] rounded-full" />
          )}
        </a>

        <!-- Separator -->
        <div class:list={["nav-sep w-px h-5 mx-2 transition-all duration-300", sepCls]}></div>

        <!-- Language Switch — fixed width to prevent layout shift between EN / 中文 -->
        <a
          href={langSwitchPath}
          data-lang-switch
          class:list={["nav-text px-3 py-2 text-sm text-center min-w-[3.25rem] transition-all duration-300 rounded-md", textMutedCls]}
        >
          {langLabel}
        </a>

        <!-- Social Icons -->
        <div class="flex items-center gap-1 ml-2">
          <a href={getLocalizedPath("/docs/", lang)} data-docsicon class:list={["nav-icon transition-all duration-300 p-1.5 rounded-md", isDocsActive ? "text-[var(--color-accent)] shadow-[0_2px_0_0_var(--color-accent)]" : iconCls]} aria-label="Docs">
            <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
            </svg>
          </a>
          <a href="https://github.com/youbinwang" target="_blank" rel="noopener noreferrer" class:list={["nav-icon transition-all duration-300 p-1.5 rounded-md", iconCls]} aria-label="GitHub">
            <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"></path>
            </svg>
          </a>
          <a href="https://www.linkedin.com/in/youbinwang/" target="_blank" rel="noopener noreferrer" class:list={["nav-icon transition-all duration-300 p-1.5 rounded-md", iconCls]} aria-label="LinkedIn">
            <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Mobile Menu Button (React Island) -->
      <div class="md:hidden">
        <MobileMenu client:media="(max-width: 767px)" navItems={allNavItems} langSwitchPath={langSwitchPath} langLabel={langLabel} />
      </div>
    </div>
  </div>
</nav>

<!-- Spacer for fixed navbar (only when NOT transparent) -->
{!transparent && <div class="h-16"></div>}

<script>
  function initNavbarScroll() {
    const nav = document.getElementById('main-nav');
    if (!nav || nav.dataset.transparent !== 'true') return;

    function updateNavbar() {
      const scrolled = window.scrollY > 80;
      const logo = nav!.querySelector('a[transition\\:name="logo"]');
      const texts = nav!.querySelectorAll('.nav-text');
      const icons = nav!.querySelectorAll('.nav-icon');
      const sep = nav!.querySelector('.nav-sep');

      if (scrolled) {
        nav!.style.backgroundColor = 'var(--color-surface-overlay)';
        nav!.style.backdropFilter = 'blur(12px)';
        nav!.style.borderBottom = '1px solid var(--color-border)';
        nav!.style.setProperty('--color-hamburger', 'var(--color-text)');
        if (logo) { logo.className = logo.className.replace(/text-white/g, 'text-[var(--color-text)]'); }
        texts.forEach(el => { el.className = el.className.replace(/text-white\/70/g, 'text-[var(--color-text-muted)]').replace(/hover:text-white/g, 'hover:text-[var(--color-text)]').replace(/\btext-white\b/g, 'text-[var(--color-text)]'); });
        icons.forEach(el => { el.className = el.className.replace(/text-white\/70/g, 'text-[var(--color-text-muted)]').replace(/hover:text-white/g, 'hover:text-[var(--color-text)]').replace(/hover:bg-white\/10/g, 'hover:bg-[var(--color-surface-hover)]'); });
        if (sep) { sep.className = sep.className.replace(/bg-white\/30/g, 'bg-[var(--color-border)]'); }
      } else {
        nav!.style.backgroundColor = 'transparent';
        nav!.style.backdropFilter = 'none';
        nav!.style.borderBottom = 'none';
        nav!.style.setProperty('--color-hamburger', 'white');
        if (logo) { logo.className = logo.className.replace(/text-\[var\(--color-text\)\]/g, 'text-white'); }
        texts.forEach(el => { el.className = el.className.replace(/text-\[var\(--color-text-muted\)\]/g, 'text-white/70').replace(/hover:text-\[var\(--color-text\)\]/g, 'hover:text-white').replace(/text-\[var\(--color-text\)\]/g, 'text-white'); });
        icons.forEach(el => { el.className = el.className.replace(/text-\[var\(--color-text-muted\)\]/g, 'text-white/70').replace(/hover:text-\[var\(--color-text\)\]/g, 'hover:text-white').replace(/hover:bg-\[var\(--color-surface-hover\)\]/g, 'hover:bg-white/10'); });
        if (sep) { sep.className = sep.className.replace(/bg-\[var\(--color-border\)\]/g, 'bg-white/30'); }
      }
    }

    window.addEventListener('scroll', updateNavbar, { passive: true });
    updateNavbar();
  }

  initNavbarScroll();
  document.addEventListener('astro:after-swap', initNavbarScroll);

  // ── Active nav state (runs after every SPA navigation) ──────────────
  const OTHER_WORKS_PATHS = ['/photography/', '/graphic-design/', '/music/'];

  function isPathActive(href: string, path: string): boolean {
    if (href === '/' || href === '/en/') return path === href;
    return path.startsWith(href);
  }

  function updateActiveNav() {
    const nav = document.getElementById('main-nav');
    if (!nav) return;
    const path = window.location.pathname;
    const isTransparent = nav.dataset.transparent === 'true';
    const isScrolled = window.scrollY > 80;
    const useDarkText = !isTransparent || isScrolled;

    const activeText = useDarkText ? 'text-[var(--color-text)]' : 'text-white';
    const mutedText  = useDarkText ? 'text-[var(--color-text-muted)]' : 'text-white/70';
    const mutedHover = useDarkText ? 'hover:text-[var(--color-text)]' : 'hover:text-white';

    const isDocsPage = path.startsWith('/docs/') || path.startsWith('/en/docs/');
    const isOtherWorksPage = !isDocsPage && OTHER_WORKS_PATHS.some(p => isPathActive(p, path));

    // Regular nav links
    nav.querySelectorAll<HTMLAnchorElement>('[data-navlink]').forEach(link => {
      const href = link.dataset.navlink!;
      const active = isPathActive(href, path);
      link.classList.remove('text-[var(--color-text)]', 'text-white', 'text-[var(--color-text-muted)]', 'text-white/70', 'hover:text-[var(--color-text)]', 'hover:text-white');
      link.classList.add(active ? activeText : mutedText);
      if (!active) link.classList.add(mutedHover);
      // underline bar
      const bar = link.querySelector('.nav-active-bar');
      if (active && !bar) {
        const span = document.createElement('span');
        span.className = 'nav-active-bar absolute bottom-0 left-3 right-3 h-0.5 bg-[var(--color-accent)] rounded-full';
        link.appendChild(span);
      } else if (!active && bar) {
        bar.remove();
      }
    });

    // Other Works button
    const otherBtn = nav.querySelector<HTMLButtonElement>('[data-otherworks]');
    if (otherBtn) {
      otherBtn.classList.remove('text-[var(--color-text)]', 'text-white', 'text-[var(--color-text-muted)]', 'text-white/70', 'hover:text-[var(--color-text)]', 'hover:text-white');
      otherBtn.classList.add(isOtherWorksPage ? activeText : mutedText);
      if (!isOtherWorksPage) otherBtn.classList.add(mutedHover);
      const bar = otherBtn.querySelector('.nav-active-bar');
      if (isOtherWorksPage && !bar) {
        const span = document.createElement('span');
        span.className = 'nav-active-bar absolute bottom-0 left-3 right-3 h-0.5 bg-[var(--color-accent)] rounded-full';
        otherBtn.appendChild(span);
      } else if (!isOtherWorksPage && bar) {
        bar.remove();
      }
    }

    // Docs icon
    const docsIcon = nav.querySelector<HTMLAnchorElement>('[data-docsicon]');
    if (docsIcon) {
      docsIcon.classList.remove(
        'text-[var(--color-accent)]',
        'text-[var(--color-text-muted)]', 'text-white/70',
        'hover:text-[var(--color-text)]', 'hover:text-white',
        'hover:bg-[var(--color-surface-hover)]', 'hover:bg-white/10'
      );
      if (isDocsPage) {
        docsIcon.classList.add('text-[var(--color-accent)]');
      } else if (useDarkText) {
        docsIcon.classList.add('text-[var(--color-text-muted)]', 'hover:text-[var(--color-text)]', 'hover:bg-[var(--color-surface-hover)]');
      } else {
        docsIcon.classList.add('text-white/70', 'hover:text-white', 'hover:bg-white/10');
      }
      docsIcon.classList.toggle('shadow-[0_2px_0_0_var(--color-accent)]', isDocsPage);
    }
  }

  updateActiveNav();
  document.addEventListener('astro:after-swap', updateActiveNav);
</script>
