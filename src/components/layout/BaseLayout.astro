---
/**
 * BaseLayout — wraps all custom Astro pages with consistent head, nav, footer.
 * Includes View Transitions for smooth page changes and scroll animation observer.
 * Supports Light/Dark mode via prefers-color-scheme (default: Light).
 * Starlight docs use their own layout; this is for portfolio pages only.
 */
import { ClientRouter } from "astro:transitions";
import Navbar from "./Navbar.astro";
import Footer from "./Footer.astro";
import type { Lang } from "../../i18n/config";
import "../../styles/global.css";

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  /** Optional OG image for social sharing */
  ogImage?: string;
  /** Navbar starts transparent over hero image */
  transparentNav?: boolean;
}

const {
  title,
  description = "Youbin Wang — Gameplay / Combat / Level Designer",
  lang,
  ogImage,
  transparentNav = false,
} = Astro.props;
const htmlLang = lang === "en" ? "en" : "zh-CN";
const canonicalUrl = new URL(
  Astro.url.pathname,
  Astro.site || "https://www.youbinwang.com",
);
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <title>{title} | Youbin Wang</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonicalUrl.href} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | Youbin Wang`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Preconnect for external resources -->
    <link rel="preconnect" href="https://images.squarespace-cdn.com" />
    <link rel="preconnect" href="https://i.ytimg.com" />

    <!-- Client-side router for smooth page transitions -->
    <ClientRouter />
  </head>
  <body
    class="min-h-screen bg-bg text-foreground font-sans antialiased transition-colors duration-200"
  >
    <Navbar lang={lang} transparent={transparentNav} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />

    <!-- Scroll-driven entrance animation observer -->
    <script>
      function initScrollAnimations() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
        );

        document
          .querySelectorAll(".animate-on-scroll, .stagger-children")
          .forEach((el) => {
            observer.observe(el);
          });
      }

      // Run on initial load
      initScrollAnimations();

      // Re-run after View Transition navigations
      document.addEventListener("astro:after-swap", initScrollAnimations);
    </script>
  </body>
</html>
