---
/**
 * BaseLayout — wraps all custom Astro pages with consistent head, nav, footer.
 * Includes ClientRouter for smooth page changes and scroll animation observer.
 * Supports Light/Dark mode via prefers-color-scheme (default: Light).
 * Starlight docs use their own layout; this is for portfolio pages only.
 */
import { ClientRouter } from "astro:transitions";
import Navbar from "./Navbar.astro";
import Footer from "./Footer.astro";
import type { Lang } from "../../i18n/config";
import "../../styles/global.css";

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  /** Navbar starts transparent over hero image */
  transparentNav?: boolean;
  /** Force dark appearance regardless of system theme (e.g. gallery pages) */
  forceDark?: boolean;
}

const {
  title,
  description = "Youbin Wang — Gameplay / Combat / Level Designer",
  lang,
  transparentNav = false,
  forceDark = false,
} = Astro.props;
const htmlLang = lang === "en" ? "en" : "zh-CN";
const canonicalUrl = new URL(
  Astro.url.pathname,
  Astro.site || "https://www.youbinwang.com",
);
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <title>{title} | Youbin Wang</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonicalUrl.href} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | Youbin Wang`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />

    <!-- Preconnect for external resources -->
    <link rel="preconnect" href="https://i.ytimg.com" />

    <!-- Client-side router for smooth page transitions -->
    <ClientRouter />
  </head>
  <body
    class:list={[
      "min-h-screen bg-bg text-foreground font-sans antialiased transition-colors duration-200",
      forceDark && "force-dark",
    ]}
  >
    <Navbar lang={lang} transparent={transparentNav} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />

    <!-- Scroll-to-top button -->
    <button
      id="scroll-top-btn"
      aria-label="Scroll to top"
      class="fixed bottom-6 right-6 z-50 w-10 h-10 rounded-full bg-[var(--color-surface)] border border-[var(--color-border)] shadow-md flex items-center justify-center text-[var(--color-text-secondary)] hover:text-[var(--color-text)] opacity-0 pointer-events-none transition-all duration-300 cursor-pointer"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
      </svg>
    </button>

    <!-- Fix Starlight theme during View Transitions.
         Starlight server-renders data-theme="dark"; this ensures the correct
         theme is applied to the incoming document before the swap. -->
    <script is:inline>
      document.addEventListener("astro:before-swap", (e) => {
        const storedTheme =
          typeof localStorage !== "undefined" &&
          localStorage.getItem("starlight-theme");
        const theme =
          storedTheme ||
          (window.matchMedia("(prefers-color-scheme: light)").matches
            ? "light"
            : "dark");
        e.newDocument.documentElement.dataset.theme = theme;
      });
    </script>

    <!-- Scroll-driven entrance animation observer -->
    <script>
      function initScrollAnimations() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
        );

        document
          .querySelectorAll(".animate-on-scroll, .stagger-children")
          .forEach((el) => {
            observer.observe(el);
          });
      }

      // Run on initial load
      initScrollAnimations();

      // Re-run after View Transition navigations
      document.addEventListener("astro:after-swap", initScrollAnimations);
    </script>

    <!-- Scroll-to-top button logic -->
    <script>
      function initScrollTopBtn() {
        const btn = document.getElementById("scroll-top-btn");
        if (!btn) return;

        const onScroll = () => {
          if (window.scrollY > 500) {
            btn.classList.remove("opacity-0", "pointer-events-none");
            btn.classList.add("opacity-100", "pointer-events-auto");
          } else {
            btn.classList.remove("opacity-100", "pointer-events-auto");
            btn.classList.add("opacity-0", "pointer-events-none");
          }
        };

        btn.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });

        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();

        document.addEventListener("astro:before-swap", () => {
          window.removeEventListener("scroll", onScroll);
        }, { once: true });
      }

      initScrollTopBtn();
      document.addEventListener("astro:after-swap", initScrollTopBtn);
    </script>

    <!-- Preserve scroll position across language switch -->
    <script>
      function initLangSwitchScrollSave() {
        document.querySelectorAll<HTMLAnchorElement>("[data-lang-switch]").forEach((link) => {
          link.addEventListener("click", () => {
            sessionStorage.setItem("langSwitchScroll", String(window.scrollY));
          });
        });
      }

      function restoreLangSwitchScroll() {
        const saved = sessionStorage.getItem("langSwitchScroll");
        if (saved === null) return;
        sessionStorage.removeItem("langSwitchScroll");
        // Override ClientRouter's default scroll-to-top by jumping to saved Y
        window.scrollTo(0, parseInt(saved, 10));
      }

      initLangSwitchScrollSave();
      restoreLangSwitchScroll();
      document.addEventListener("astro:after-swap", () => {
        initLangSwitchScrollSave();
        restoreLangSwitchScroll();
      });
    </script>
  </body>
</html>
