---
/**
 * Renders an inline-features MDX entry with layout components auto-injected.
 * The parent ([slug].astro) calls render() to get Content + headings;
 * Content is passed here so headings remain available to the parent for TOC.
 */
import TextImage from '../mdx/TextImage.astro';
import ImageRow from '../mdx/ImageRow.astro';
import ImageGrid from '../mdx/ImageGrid.astro';

interface Props {
  Content: any;
}

const { Content } = Astro.props;
---

{Content && (
  <div class="inline-features-content max-w-none">
    <Content components={{ TextImage, ImageRow, ImageGrid }} />
  </div>
)}

<style is:global>
  /* Inline-features MDX typography — see CLAUDE.md 字号规范 */
  .inline-features-content {
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  /* h2: page Section h2 小一级（20px → md:24px），左竖条锚点替代下划线 */
  .inline-features-content h2 {
    font-size: 1.25rem;       /* 20px */
    line-height: 1.3;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-text);
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-left: 0.875rem;
    border-left: 4px solid var(--color-accent);
  }
  .inline-features-content > :first-child h2,
  .inline-features-content > h2:first-child {
    margin-top: 0;
  }
  @media (min-width: 768px) {
    .inline-features-content h2 {
      font-size: 1.5rem;      /* 24px */
    }
  }

  .inline-features-content h3 {
    font-size: 1.125rem;      /* 18px */
    line-height: 1.4;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .inline-features-content h4 {
    font-size: 1rem;          /* 16px */
    line-height: 1.5;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .inline-features-content p {
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0.75rem 0;
  }

  .inline-features-content strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .inline-features-content a {
    color: var(--color-accent);
    text-decoration: none;
  }
  .inline-features-content a:hover {
    text-decoration: underline;
  }

  .inline-features-content ul,
  .inline-features-content ol {
    margin: 0.75rem 0;
    padding-left: 1.5rem;
    color: var(--color-text-secondary);
  }
  .inline-features-content li {
    margin: 0.25rem 0;
  }
  .inline-features-content ul > li {
    list-style: disc;
  }
  .inline-features-content ol > li {
    list-style: decimal;
  }

  .inline-features-content img {
    border-radius: 0.5rem;
    margin: 1rem 0;
  }
</style>
