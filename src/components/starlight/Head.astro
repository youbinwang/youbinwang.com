---
/**
 * Custom Starlight Head — extends default Starlight <head> content
 * and injects Astro's ClientRouter for unified View Transitions
 * across portfolio pages and documentation pages.
 *
 * Also fixes:
 * 1. Theme flash: Starlight server-renders data-theme="dark",
 *    but the StarlightThemeProvider IIFE doesn't re-run during View Transitions.
 * 2. CustomElements crash: Starlight defines custom elements (starlight-theme-select,
 *    starlight-tabs, etc.) via inline scripts. When ClientRouter re-executes these
 *    scripts on soft navigation, customElements.define() throws because the name
 *    is already registered. We monkey-patch define() to be idempotent.
 */
import type { Props } from "@astrojs/starlight/props";
import Default from "@astrojs/starlight/components/Head.astro";
import { ClientRouter } from "astro:transitions";
---

<!-- Patch customElements.define to be idempotent.
     Must run BEFORE Starlight's scripts that call customElements.define().
     During ClientRouter soft navigation, Starlight's IIFE scripts may
     re-execute and try to define already-registered custom elements,
     which throws NotSupportedError. This patch silently skips duplicates. -->
<script is:inline>
    (function () {
        const orig = customElements.define.bind(customElements);
        customElements.define = function (name, ctor, opts) {
            if (!customElements.get(name)) orig(name, ctor, opts);
        };
    })();
</script>

<Default {...Astro.props}><slot /></Default>
<ClientRouter />

<!-- Fix theme mismatch during View Transitions.
     Starlight server-renders data-theme="dark" (server can't detect user preference).
     On normal load the StarlightThemeProvider IIFE corrects it, but during
     ClientRouter swap the IIFE doesn't re-run. This listener patches the
     incoming document's <html> before the swap so no flash occurs. -->
<script is:inline>
    document.addEventListener("astro:before-swap", (e) => {
        const storedTheme =
            typeof localStorage !== "undefined" &&
            localStorage.getItem("starlight-theme");
        const theme =
            storedTheme ||
            (window.matchMedia("(prefers-color-scheme: light)").matches
                ? "light"
                : "dark");
        e.newDocument.documentElement.dataset.theme = theme;
    });
</script>

<!-- Scroll-to-top button for Starlight docs pages
     (Portfolio pages get theirs from BaseLayout.astro) -->
<script>
    function initDocsScrollTopBtn() {
        const ID = "scroll-top-btn";
        // Skip if already present (e.g. navigated from a Portfolio page)
        if (document.getElementById(ID)) return;

        const btn = document.createElement("button");
        btn.id = ID;
        btn.setAttribute("aria-label", "Scroll to top");
        btn.innerHTML = `<svg style="width:1.25rem;height:1.25rem" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>`;
        Object.assign(btn.style, {
            position: "fixed",
            bottom: "1.5rem",
            right: "1.5rem",
            zIndex: "50",
            width: "2.5rem",
            height: "2.5rem",
            borderRadius: "9999px",
            background: "var(--color-surface, var(--sl-color-bg))",
            border: "1px solid var(--color-border, var(--sl-color-hairline))",
            boxShadow: "0 1px 3px var(--color-border)",
            display: "flex",
            alignItems: "center",
            justifyContent: "center",
            color: "var(--color-text-secondary, var(--sl-color-gray-3))",
            opacity: "0",
            pointerEvents: "none",
            transition: "all 300ms",
            cursor: "pointer",
        });
        document.body.appendChild(btn);

        const onScroll = () => {
            if (window.scrollY > 500) {
                btn.style.opacity = "1";
                btn.style.pointerEvents = "auto";
            } else {
                btn.style.opacity = "0";
                btn.style.pointerEvents = "none";
            }
        };

        btn.addEventListener("click", () => {
            window.scrollTo({ top: 0, behavior: "smooth" });
        });
        btn.addEventListener("mouseenter", () => {
            btn.style.color = "var(--color-text, var(--sl-color-white))";
        });
        btn.addEventListener("mouseleave", () => {
            btn.style.color =
                "var(--color-text-secondary, var(--sl-color-gray-3))";
        });

        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();

        document.addEventListener(
            "astro:before-swap",
            () => {
                window.removeEventListener("scroll", onScroll);
                btn.remove();
            },
            { once: true },
        );
    }

    initDocsScrollTopBtn();
    document.addEventListener("astro:after-swap", initDocsScrollTopBtn);
</script>

<!-- Preserve scroll position across language switch (Docs pages) -->
<script>
    function initDocsLangSwitchScrollSave() {
        document.querySelectorAll<HTMLAnchorElement>("[data-lang-switch]").forEach((link) => {
            link.addEventListener("click", () => {
                sessionStorage.setItem("langSwitchScroll", String(window.scrollY));
            });
        });
    }

    function restoreDocsLangSwitchScroll() {
        const saved = sessionStorage.getItem("langSwitchScroll");
        if (saved === null) return;
        sessionStorage.removeItem("langSwitchScroll");
        window.scrollTo(0, parseInt(saved, 10));
    }

    initDocsLangSwitchScrollSave();
    restoreDocsLangSwitchScroll();
    document.addEventListener("astro:after-swap", () => {
        initDocsLangSwitchScrollSave();
        restoreDocsLangSwitchScroll();
    });
</script>

<!-- PhotoSwipe lightbox for inline docs images -->
<script>
    import PhotoSwipeLightbox from "photoswipe/lightbox";
    import PhotoSwipe from "photoswipe";
    import { addThumbnailStrip } from "../../utils/pswp-thumbnails";

    let currentLightbox: PhotoSwipeLightbox | null = null;

    function initDocsLightbox() {
        // Destroy previous instance to prevent memory leak on repeated navigation
        if (currentLightbox) {
            currentLightbox.destroy();
            currentLightbox = null;
        }

        const content = document.querySelector<HTMLElement>(".sl-markdown-content");
        if (!content) return;

        content.querySelectorAll<HTMLImageElement>("img").forEach((img) => {
            if (img.closest("a[data-pswp-width]")) return;

            const a = document.createElement("a");
            a.href = img.src;
            a.setAttribute("data-pswp-width", "1600");
            a.setAttribute("data-pswp-height", "900");
            a.className = "docs-pswp-link";

            img.parentElement!.insertBefore(a, img);
            a.appendChild(img);

            const update = () => {
                if (img.naturalWidth > 0) {
                    a.setAttribute("data-pswp-width", String(img.naturalWidth));
                    a.setAttribute("data-pswp-height", String(img.naturalHeight));
                }
            };
            img.complete && img.naturalWidth > 0
                ? update()
                : img.addEventListener("load", update);
        });

        const links = content.querySelectorAll("a[data-pswp-width]");
        if (links.length === 0) return;

        currentLightbox = new PhotoSwipeLightbox({
            gallery: content,
            children: "a[data-pswp-width]",
            pswpModule: PhotoSwipe,
        });

        // At click time, read actual image dimensions (fixes first-click-before-load issue)
        currentLightbox.addFilter('domItemData', (itemData, _element, linkEl) => {
            const img = (linkEl as HTMLElement).querySelector('img');
            if (img && img.naturalWidth > 0) {
                itemData.w = img.naturalWidth;
                itemData.h = img.naturalHeight;
            }
            return itemData;
        });

        addThumbnailStrip(currentLightbox, content, "a[data-pswp-width]");
        currentLightbox.init();
    }

    initDocsLightbox();
    document.addEventListener("astro:after-swap", initDocsLightbox);
</script>
