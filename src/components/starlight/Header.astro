---
/**
 * Custom Starlight Header — replaces default Starlight header
 * to unify navigation across portfolio and documentation pages.
 *
 * Important: Starlight's PageFrame already wraps this in a
 * `<header class="header">` that is position:fixed with its own
 * height/padding/background. So we must NOT use Navbar's fixed
 * positioning here — instead we render nav items inline.
 */
import type { Props as StarlightProps } from "@astrojs/starlight/props";
import type { Lang } from "../../i18n/config";
import { getLocalizedPath, uiEN } from "../../i18n";

const lang: Lang = Astro.url.pathname.startsWith("/en/") ? "en" : "zh-cn";
const langLabel = lang === "en" ? "中文" : "EN";
const langSwitchPath =
    lang === "en"
        ? Astro.url.pathname.replace(/^\/en/, "") || "/"
        : `/en${Astro.url.pathname}`;

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
    if (href === "/" || href === "/en/") return currentPath === href;
    return currentPath.startsWith(href);
}

const navItems = [
    { label: uiEN("nav.home"), href: getLocalizedPath("/", lang) },
    { label: uiEN("nav.games"), href: getLocalizedPath("/games/", lang) },
    { label: uiEN("nav.films"), href: getLocalizedPath("/films/", lang) },
];

const otherWorksItems = [
    {
        label: uiEN("nav.photography"),
        href: getLocalizedPath("/photography/", lang),
    },
    {
        label: uiEN("nav.graphicDesign"),
        href: getLocalizedPath("/graphic-design/", lang),
    },
    { label: uiEN("nav.music"), href: getLocalizedPath("/music/", lang) },
];

const aboutItem = {
    label: uiEN("nav.about"),
    href: getLocalizedPath("/about/", lang),
};

const isDocsActive =
    currentPath.startsWith("/docs/") || currentPath.startsWith("/en/docs/");
const isOtherWorksActive = otherWorksItems.some((item) => isActive(item.href));
---

<div class="docs-header-inner max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a href={getLocalizedPath("/", lang)} class="docs-logo"> Youbin Wang </a>

    <!-- Desktop Navigation -->
    <div class="docs-nav-desktop">
        {
            navItems.map((item) => (
                <a
                    href={item.href}
                    class:list={[
                        "docs-nav-link",
                        { active: isActive(item.href) },
                    ]}
                >
                    {item.label}
                </a>
            ))
        }

        <!-- Other Works Dropdown -->
        <div class="docs-dropdown">
            <button
                class:list={[
                    "docs-nav-link docs-dropdown-trigger",
                    { active: isOtherWorksActive },
                ]}
                aria-expanded="false"
                aria-haspopup="true"
            >
                {uiEN("nav.otherWorks")}
                <svg
                    class="docs-chevron"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 9l-7 7-7-7"></path>
                </svg>
            </button>
            <div class="docs-dropdown-menu" role="menu">
                {
                    otherWorksItems.map((item) => (
                        <a
                            href={item.href}
                            class:list={[
                                "docs-dropdown-item",
                                { active: isActive(item.href) },
                            ]}
                            role="menuitem"
                        >
                            {item.label}
                        </a>
                    ))
                }
            </div>
        </div>

        <a
            href={aboutItem.href}
            class:list={["docs-nav-link", { active: isActive(aboutItem.href) }]}
        >
            {aboutItem.label}
        </a>

        <!-- Separator -->
        <div class="docs-sep"></div>

        <!-- Language Switch -->
        <a href={langSwitchPath} data-lang-switch class="docs-nav-link docs-lang-switch">
            {langLabel}
        </a>

        <!-- Social Icons -->
        <div class="docs-social-icons">
            <a
                href={getLocalizedPath("/docs/", lang)}
                class:list={["docs-icon-link", { active: isDocsActive }]}
                aria-label="Docs"
            >
                <svg
                    class="docs-icon"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                    <path
                        d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"
                    ></path>
                </svg>
            </a>
            <a
                href="https://github.com/youbinwang"
                target="_blank"
                rel="noopener noreferrer"
                class="docs-icon-link"
                aria-label="GitHub"
            >
                <svg class="docs-icon" viewBox="0 0 24 24" fill="currentColor">
                    <path
                        d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
                    ></path>
                </svg>
            </a>
            <a
                href="https://www.linkedin.com/in/youbinwang/"
                target="_blank"
                rel="noopener noreferrer"
                class="docs-icon-link"
                aria-label="LinkedIn"
            >
                <svg class="docs-icon" viewBox="0 0 24 24" fill="currentColor">
                    <path
                        d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                    ></path>
                </svg>
            </a>
        </div>
    </div>
</div>

<style>
    /* ── Docs Header (inside Starlight's fixed <header>) ────────────── */
    /* Width & padding handled by Tailwind classes: max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8
       — identical to Portfolio Navbar for pixel-perfect alignment */
    .docs-header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 100%;
    }

    /* Logo — no underline ever */
    .docs-logo {
        font-weight: 700;
        font-size: 1.25rem;
        letter-spacing: 0.025em;
        color: var(--color-text, var(--sl-color-white));
        text-decoration: none !important;
        border: none !important;
        white-space: nowrap;
        transition: opacity 0.15s ease;
        /* Match Navbar's transition:name="logo" so View Transitions
           morphs between them instead of separate fadeOut/fadeIn */
        view-transition-name: logo;
    }
    .docs-logo:hover {
        opacity: 0.8;
        text-decoration: none !important;
        color: var(--color-text, var(--sl-color-white));
    }

    /* Nav links */
    .docs-nav-desktop {
        display: none;
        align-items: center;
        gap: 0.25rem;
    }
    @media (min-width: 48rem) {
        .docs-nav-desktop {
            display: flex;
        }
    }

    .docs-nav-link {
        position: relative;
        padding: 0.5rem 0.75rem;
        font-size: 0.875rem;
        color: var(--color-text-muted, var(--sl-color-gray-3));
        text-decoration: none !important;
        border: none !important;
        background: none;
        cursor: pointer;
        font-family: inherit;
        transition: color 0.15s ease;
        white-space: nowrap;
    }
    .docs-nav-link:hover {
        color: var(--color-text, var(--sl-color-white));
        text-decoration: none !important;
    }
    .docs-nav-link.active {
        color: var(--color-text, var(--sl-color-white));
    }
    .docs-nav-link.active::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0.75rem;
        right: 0.75rem;
        height: 2px;
        background: var(--color-accent, var(--sl-color-accent));
        border-radius: 1px;
    }

    /* Separator */
    .docs-sep {
        width: 1px;
        height: 1.25rem;
        margin: 0 0.5rem;
        background: var(--color-border, var(--sl-color-gray-5));
    }

    /* Language switch — no active underline, fixed width to prevent EN/中文 layout shift */
    .docs-lang-switch::after {
        display: none !important;
    }
    .docs-lang-switch {
        min-width: 3.25rem;
        text-align: center;
    }

    /* Dropdown */
    .docs-dropdown {
        position: relative;
    }
    .docs-dropdown-trigger {
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }
    .docs-chevron {
        width: 0.75rem;
        height: 0.75rem;
        transition: transform 0.2s ease;
    }
    .docs-dropdown:hover .docs-chevron,
    .docs-dropdown:focus-within .docs-chevron {
        transform: rotate(180deg);
    }
    .docs-dropdown-menu {
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        margin-top: 0.25rem;
        padding: 0.5rem 0;
        background: var(--color-surface, var(--sl-color-bg-nav));
        border: 1px solid var(--color-border, var(--sl-color-gray-5));
        border-radius: 0.5rem;
        box-shadow: 0 10px 25px var(--color-border-strong);
        opacity: 0;
        visibility: hidden;
        transition:
            opacity 0.2s ease,
            visibility 0.2s ease;
        min-width: 180px;
        z-index: 100;
    }
    .docs-dropdown:hover .docs-dropdown-menu,
    .docs-dropdown:focus-within .docs-dropdown-menu {
        opacity: 1;
        visibility: visible;
    }
    .docs-dropdown-item {
        display: block;
        padding: 0.625rem 1rem;
        font-size: 0.875rem;
        color: var(--color-text-secondary, var(--sl-color-gray-2));
        text-decoration: none !important;
        border: none !important;
        transition:
            color 0.15s ease,
            background-color 0.15s ease;
    }
    .docs-dropdown-item:hover {
        color: var(--color-text, var(--sl-color-white));
        background-color: var(--color-surface-hover, var(--sl-color-gray-6));
        text-decoration: none !important;
    }
    .docs-dropdown-item.active {
        color: var(--color-text, var(--sl-color-white));
        background-color: var(--color-accent-bg);
    }

    /* Social Icons */
    .docs-social-icons {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        margin-left: 0.5rem;
    }
    .docs-icon-link {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.375rem;
        border-radius: 0.375rem;
        color: var(--color-text-muted, var(--sl-color-gray-3));
        text-decoration: none !important;
        border: none !important;
        transition:
            color 0.15s ease,
            background-color 0.15s ease;
    }
    .docs-icon-link:hover {
        color: var(--color-text, var(--sl-color-white));
        background-color: var(--color-surface-hover, var(--sl-color-gray-6));
        text-decoration: none !important;
    }
    .docs-icon-link.active {
        color: var(--color-accent, var(--sl-color-accent));
        box-shadow: 0 2px 0 0 var(--color-accent, var(--sl-color-accent));
    }
    .docs-icon {
        width: 18px;
        height: 18px;
    }
</style>
