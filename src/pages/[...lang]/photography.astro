---
/**
 * Photography page — masonry photo grid with PhotoSwipe lightbox (native Astro script).
 */
import BaseLayout from "../../components/layout/BaseLayout.astro";
import PageHeader from "../../components/ui/PageHeader.astro";
import { getLangFromSlug, ui, uiEN } from "../../i18n";

export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: "en" } }];
}

const lang = getLangFromSlug(Astro.params.lang);

const NUM_COLS = 3;
const photos: string[] = [
  "/images/photography/photo-01.png",
  "/images/photography/photo-02.jpg",
  "/images/photography/photo-03.png",
  "/images/photography/photo-04.jpg",
  "/images/photography/photo-05.jpg",
  "/images/photography/photo-06.jpg",
  "/images/photography/photo-07.jpg",
  "/images/photography/photo-08.png",
  "/images/photography/photo-09.jpeg",
  "/images/photography/photo-10.jpg",
  "/images/photography/photo-11.png",
  "/images/photography/photo-12.jpg",
  "/images/photography/photo-13.jpg",
  "/images/photography/photo-14.jpg",
  "/images/photography/photo-15.png",
  "/images/photography/photo-16.jpg",
  "/images/photography/photo-17.png",
  "/images/photography/photo-18.png",
  "/images/photography/photo-19.jpg",
  "/images/photography/photo-20.png",
  "/images/photography/photo-21.png",
  "/images/photography/photo-22.png",
  "/images/photography/photo-23.png",
  "/images/photography/photo-24.jpg",
  "/images/photography/photo-25.png",
  "/images/photography/photo-26.png",
  "/images/photography/photo-27.jpg",
  "/images/photography/photo-28.jpg",
  "/images/photography/photo-29.png",
  "/images/photography/photo-30.jpeg",
  "/images/photography/photo-31.jpg",
  "/images/photography/photo-32.jpeg",
  "/images/photography/photo-33.png",
  "/images/photography/photo-34.png",
];

const columns: string[][] = Array.from({ length: NUM_COLS }, (_, col) =>
  photos.filter((_, i) => i % NUM_COLS === col)
);
---

<BaseLayout title={uiEN("photography.title")} lang={lang} forceDark>
  <section class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <PageHeader
      title={ui("photography.title", lang)}
      subtitle="Landscape & Documentary Photography"
    />

    {/* Quote */}
    <blockquote class="mb-12 max-w-2xl mx-auto text-center">
      <p class="text-xl italic text-[var(--color-text)]">
        "We had longer ways to go. But no matter, the road is life."
      </p>
      <cite class="mt-3 block text-sm text-[var(--color-text-secondary)] text-right"
        >— Jack Kerouac</cite
      >
    </blockquote>

    {
      photos.length > 0 ? (
        <div id="photography-gallery" class="flex gap-3">
          {columns.map((col) => (
            <div class="flex flex-col gap-3 flex-1 min-w-0">
              {col.map((src) => (
                <a
                  href={src}
                  data-pswp-width="2000"
                  data-pswp-height="2000"
                  class="group relative block overflow-hidden rounded-lg cursor-zoom-in"
                >
                  <img
                    src={src}
                    alt="Photography"
                    class="w-full h-auto object-cover transition-transform duration-[400ms] group-hover:scale-[1.03]"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-black/0 group-hover:bg-black/35 transition-colors duration-[400ms] flex items-center justify-center">
                    <svg
                      class="w-10 h-10 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-[400ms] drop-shadow-lg"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      viewBox="0 0 24 24"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0zm0 0v.01M11 8v6m-3-3h6" />
                    </svg>
                  </div>
                </a>
              ))}
            </div>
          ))}
        </div>
      ) : (
        <p class="text-center text-[var(--color-text-muted)]">
          {lang === "zh-cn" ? "照片即将上线..." : "Photos coming soon..."}
        </p>
      )
    }
  </section>
</BaseLayout>

<script>
  import PhotoSwipeLightbox from "photoswipe/lightbox";
  import PhotoSwipe from "photoswipe";

  function initGallery() {
    const gallery = document.querySelector<HTMLElement>("#photography-gallery");
    if (!gallery) return;

    const lightbox = new PhotoSwipeLightbox({
      gallery,
      children: "a",
      pswpModule: PhotoSwipe,
    });

    gallery.querySelectorAll<HTMLAnchorElement>("a").forEach((link) => {
      const img = link.querySelector("img");
      if (!img) return;
      const update = () => {
        if (img.naturalWidth > 0) {
          link.setAttribute("data-pswp-width", String(img.naturalWidth));
          link.setAttribute("data-pswp-height", String(img.naturalHeight));
        }
      };
      if (img.complete && img.naturalWidth > 0) {
        update();
      } else {
        img.addEventListener("load", update);
      }
    });

    lightbox.init();
    document.addEventListener("astro:before-swap", () => lightbox.destroy(), {
      once: true,
    });
  }

  initGallery();
  document.addEventListener("astro:after-swap", initGallery);
</script>
