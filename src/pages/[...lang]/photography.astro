---
/**
 * Photography page — masonry photo grid with PhotoSwipe lightbox (native Astro script).
 */
import BaseLayout from "../../components/layout/BaseLayout.astro";
import PageHeader from "../../components/ui/PageHeader.astro";
import { getLangFromSlug, ui, uiEN } from "../../i18n";

export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: "en" } }];
}

const lang = getLangFromSlug(Astro.params.lang);

const photos: string[] = [];
---

<BaseLayout title={uiEN("photography.title")} lang={lang} forceDark>
  <section class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <PageHeader
      title={ui("photography.title", lang)}
      subtitle="Landscape & Documentary Photography"
    />

    {/* Quote */}
    <blockquote class="mb-16">
      <p class="text-xl italic text-[var(--color-text-secondary)]">
        "We had longer ways to go. But no matter, the road is life."
      </p>
      <cite class="mt-2 block text-sm text-[var(--color-text-muted)]"
        >— Jack Kerouac</cite
      >
    </blockquote>

    {
      photos.length > 0 ? (
        <div
          id="photography-gallery"
          class="columns-2 md:columns-3 lg:columns-4 gap-3 space-y-3"
        >
          {photos.map((src, i) => (
            <a
              href={src}
              data-pswp-width="2000"
              data-pswp-height="2000"
              class="block overflow-hidden rounded-lg cursor-zoom-in mb-3"
            >
              <img
                src={src}
                alt={`Photography ${i + 1}`}
                class="w-full h-auto object-cover transition-transform duration-300 hover:scale-105"
                loading="lazy"
              />
            </a>
          ))}
        </div>
      ) : (
        <p class="text-center text-[var(--color-text-muted)]">
          {lang === "zh-cn" ? "照片即将上线..." : "Photos coming soon..."}
        </p>
      )
    }
  </section>
</BaseLayout>

<script>
  import PhotoSwipeLightbox from "photoswipe/lightbox";
  import PhotoSwipe from "photoswipe";

  function initGallery() {
    const gallery = document.querySelector<HTMLElement>("#photography-gallery");
    if (!gallery) return;

    const lightbox = new PhotoSwipeLightbox({
      gallery,
      children: "a",
      pswpModule: PhotoSwipe,
    });

    gallery.querySelectorAll<HTMLAnchorElement>("a").forEach((link) => {
      const img = link.querySelector("img");
      if (!img) return;
      const update = () => {
        if (img.naturalWidth > 0) {
          link.setAttribute("data-pswp-width", String(img.naturalWidth));
          link.setAttribute("data-pswp-height", String(img.naturalHeight));
        }
      };
      if (img.complete && img.naturalWidth > 0) {
        update();
      } else {
        img.addEventListener("load", update);
      }
    });

    lightbox.init();
    document.addEventListener("astro:before-swap", () => lightbox.destroy(), {
      once: true,
    });
  }

  initGallery();
  document.addEventListener("astro:after-swap", initGallery);
</script>
