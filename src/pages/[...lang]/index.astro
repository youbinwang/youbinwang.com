---
/**
 * Homepage — Hero + intro bio + featured game project cards grid.
 */
import BaseLayout from "../../components/layout/BaseLayout.astro";
import HeroSection from "../../components/layout/HeroSection.astro";
import ProjectCard from "../../components/ui/ProjectCard.astro";
import { getLangFromSlug, getI18nStaticPaths, ui, getLocalizedPath } from "../../i18n";
import { games } from "../../data/games";

export const getStaticPaths = getI18nStaticPaths;

const lang = getLangFromSlug(Astro.params.lang);

// Featured games order differs by language (per original site)
const cnFeaturedSlugs = [
  "elemental-realm",
  "echo-quest",
  "the-scholars-side-quest",
  "on-the-road",
  "shepherds",
];
const enFeaturedSlugs = [
  "echo-quest",
  "elemental-realm",
  "on-the-road",
  "the-scholars-side-quest",
  "shepherds",
];
const featuredSlugs = lang === "en" ? enFeaturedSlugs : cnFeaturedSlugs;
const featuredGames = featuredSlugs
  .map((slug) => games.find((g) => g.slug === slug))
  .filter(Boolean) as typeof games;

const heroImage =
  "https://images.squarespace-cdn.com/content/v1/654b4d93bf733e56e897721b/fdc01711-6ce1-41a5-9e9c-13e8a6277954/Main+Page.png";
---

<BaseLayout title={ui("nav.home", lang)} lang={lang} transparentNav>
  {/* Hero */}
  <HeroSection
    backgroundImage={heroImage}
    title="Youbin Wang"
    subtitle="GAMEPLAY / COMBAT / LEVEL DESIGNER"
    fullHeight
  />

  {/* Introduction */}
  <section class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="max-w-4xl mx-auto">
    {
      lang === "zh-cn" ? (
        <div class="text-[var(--color-text-secondary)] text-base leading-relaxed space-y-4">
          <p>
            我是王佑彬 (Robin)，目前在<strong class="text-[var(--color-text)]">网易雷火</strong>任<strong class="text-[var(--color-text)]">玩法策划</strong>，专注于<strong class="text-[var(--color-text)]">玩法、关卡、战斗</strong>与<strong class="text-[var(--color-text)]">任务设计</strong>，同时负责<strong class="text-[var(--color-text)]">项目工具链</strong>与<strong class="text-[var(--color-text)]">生产管线</strong>的搭建与优化。我曾在 <strong class="text-[var(--color-text)]">EA Sports</strong> 和<strong class="text-[var(--color-text)]">腾讯</strong>任职，参与过<strong class="text-[var(--color-text)]">十余个不同类型游戏项目</strong>的设计与开发。
          </p>
          <p>
            我拥有丰富的<strong class="text-[var(--color-text)]">跨职能协作经验</strong>，能够熟练使用 <strong class="text-[var(--color-text)]">Unreal、Unity 引擎</strong>完成<strong class="text-[var(--color-text)]">玩法原型</strong>与<strong class="text-[var(--color-text)]">核心系统</strong>的落地实现，并使用 <strong class="text-[var(--color-text)]">Blender</strong> 进行<strong class="text-[var(--color-text)]">关卡原型</strong>的设计与搭建。此外，我将 <strong class="text-[var(--color-text)]">AI 工作流</strong>深度整合至开发管线，大幅提升项目开发与生产效率。
          </p>
          <p class="text-lg mt-6 text-[var(--color-text)]">
            欢迎探索我的作品 :D
          </p>
        </div>
      ) : (
        <div class="text-[var(--color-text-secondary)] text-base leading-relaxed space-y-4">
          <p>
            I'm Youbin Wang (Robin), currently a <strong class="text-[var(--color-text)]">Gameplay Designer</strong> at{" "}
            <strong class="text-[var(--color-text)]">NetEase (Thunder Fire Studio)</strong>, specializing in{" "}
            <strong class="text-[var(--color-text)]">Gameplay, Level, Combat, and Quest Design</strong>, while also responsible for{" "}
            <strong class="text-[var(--color-text)]">building and optimizing toolchains and production pipelines</strong>.
            Previously, I worked at <strong class="text-[var(--color-text)]">EA Sports</strong> and{" "}
            <strong class="text-[var(--color-text)]">Tencent</strong>, contributing to{" "}
            <strong class="text-[var(--color-text)]">over ten game projects of diverse genres</strong>.
          </p>
          <p>
            I bring strong <strong class="text-[var(--color-text)]">cross-functional collaboration</strong> experience, and am proficient in{" "}
            <strong class="text-[var(--color-text)]">Unreal and Unity</strong> for implementing{" "}
            <strong class="text-[var(--color-text)]">gameplay prototypes and core systems</strong>, as well as{" "}
            <strong class="text-[var(--color-text)]">Blender</strong> for{" "}
            <strong class="text-[var(--color-text)]">level prototype</strong> design and blockout.
            I also deeply integrate <strong class="text-[var(--color-text)]">AI workflows</strong> into development pipelines to significantly boost project productivity.
          </p>
          <p class="text-lg mt-6 text-[var(--color-text)]">
            Welcome to explore my works :D
          </p>
        </div>
      )
    }
    </div>
  </section>

  {/* Featured Games */}
  <section class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-text)] mb-8">
      {lang === "zh-cn" ? "游戏作品" : "Game Works"}
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {featuredGames.map((game) => <ProjectCard game={game} lang={lang} />)}
    </div>

    {/* View All CTA */}
    <div class="text-center mt-10">
      <a
        href={getLocalizedPath("/games/", lang)}
        class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium text-[var(--color-text)] bg-[var(--color-bg-secondary)] hover:bg-[var(--color-bg-tertiary)] rounded-lg border border-[var(--color-border)] transition-colors"
      >
        {lang === "zh-cn" ? "查看所有游戏作品" : "View All Game Works"}
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
