---
/**
 * Music page — sections for Music Production and Original Game Soundtrack.
 * Shows track cards with cover images and embed players (placeholders for now).
 */
import BaseLayout from "../../components/layout/BaseLayout.astro";
import { getLangFromSlug, ui, uiEN, t, getLocalizedPath } from "../../i18n";
import { getMusicByCategory } from "../../data/music";

export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: "en" } }];
}

const lang = getLangFromSlug(Astro.params.lang);
const productionTracks = getMusicByCategory("production");
const ostTracks = getMusicByCategory("ost");
---

<BaseLayout title={uiEN("music.title")} lang={lang}>
  <section class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <h1 class="text-3xl font-bold text-[var(--color-text)] mb-12 text-center">
      {ui("music.title", lang)}
    </h1>

    {/* Music Production */}
    <div class="mb-16">
      <h2
        class="text-xl font-semibold text-[var(--color-text)] mb-6 pb-3 border-b border-[var(--color-border)]"
      >
        {ui("music.production", lang)}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {
          productionTracks.map((track) => (
            <div class="flex items-center gap-4 p-4 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg hover:bg-[var(--color-surface-hover)] transition-colors">
              {/* Cover placeholder */}
              <div class="w-16 h-16 flex-shrink-0 bg-[var(--color-bg-secondary)] rounded-lg flex items-center justify-center">
                {track.coverImage ? (
                  <img
                    src={track.coverImage}
                    alt={t(track.title, lang)}
                    class="w-full h-full object-cover rounded-lg"
                  />
                ) : (
                  <svg
                    class="w-8 h-8 text-[var(--color-text-muted)]"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"
                    />
                  </svg>
                )}
              </div>
              {/* Track info */}
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-medium text-[var(--color-text)] truncate">
                  {t(track.title, lang)}
                </h3>
                <p class="text-sm text-[var(--color-text-muted)] mt-0.5">
                  {t(track.description, lang)}
                </p>
              </div>
              {/* Play button placeholder */}
              <div class="flex-shrink-0">
                <div class="w-10 h-10 rounded-full bg-[var(--color-bg-secondary)] flex items-center justify-center text-[var(--color-text-muted)]">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    {/* Original Game Soundtrack */}
    <div>
      <h2
        class="text-xl font-semibold text-[var(--color-text)] mb-6 pb-3 border-b border-[var(--color-border)]"
      >
        {ui("music.ost", lang)}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {
          ostTracks.map((track) => (
            <div class="flex items-center gap-4 p-4 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg hover:bg-[var(--color-surface-hover)] transition-colors">
              {/* Cover placeholder */}
              <div class="w-16 h-16 flex-shrink-0 bg-[var(--color-bg-secondary)] rounded-lg flex items-center justify-center">
                {track.coverImage ? (
                  <img
                    src={track.coverImage}
                    alt={t(track.title, lang)}
                    class="w-full h-full object-cover rounded-lg"
                  />
                ) : (
                  <svg
                    class="w-8 h-8 text-[var(--color-text-muted)]"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"
                    />
                  </svg>
                )}
              </div>
              {/* Track info */}
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-medium text-[var(--color-text)] truncate">
                  {t(track.title, lang)}
                </h3>
                <p class="text-sm text-[var(--color-text-muted)] mt-0.5">
                  {t(track.description, lang)}
                </p>
                {track.relatedGameSlug && (
                  <a
                    href={getLocalizedPath(
                      `/games/${track.relatedGameSlug}/`,
                      lang,
                    )}
                    class="inline-flex items-center gap-1 text-xs text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors mt-1"
                  >
                    {lang === "zh-cn" ? "查看游戏项目" : "View Game Project"}
                    <svg
                      class="w-3 h-3"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 5l7 7-7 7"
                      />
                    </svg>
                  </a>
                )}
              </div>
              {/* Play button placeholder */}
              <div class="flex-shrink-0">
                <div class="w-10 h-10 rounded-full bg-[var(--color-bg-secondary)] flex items-center justify-center text-[var(--color-text-muted)]">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
