---
/**
 * Films list page — full-viewport cinematic experience.
 * Background fills the screen; hovering a title crossfades to that film's image.
 */
import BaseLayout from "../../../components/layout/BaseLayout.astro";
import { getLangFromSlug, getI18nStaticPaths, uiEN, t, getLocalizedPath } from "../../../i18n";
import { getFilmsByOrder } from "../../../data/films";

export const getStaticPaths = getI18nStaticPaths;

const lang = getLangFromSlug(Astro.params.lang);
const films = getFilmsByOrder();
---

<BaseLayout
  title={uiEN("films.title")}
  lang={lang}
  transparentNav={true}
  forceDark={true}
>
  <div class="relative h-screen overflow-hidden" id="films-stage">

    <!-- Background layers: stacked, crossfade on hover -->
    {films.map((film, i) => (
      <div
        class="absolute inset-0 transition-[opacity] duration-700 ease-in-out"
        style={i === 0 ? "opacity:1" : "opacity:0"}
        data-film-bg={i}
      >
        <img
          src={film.coverImage}
          alt=""
          class="w-full h-full object-cover"
          loading={i === 0 ? "eager" : "lazy"}
        />
        <!-- Dark vignette: stronger at edges, lighter in centre -->
        <div
          class="absolute inset-0"
          style="background: radial-gradient(ellipse at 30% 50%, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0.6) 100%);"
        />
      </div>
    ))}

    <!-- Film titles — vertically centred, left-aligned -->
    <div class="relative z-10 h-full flex items-center">
      <div class="max-w-screen-xl mx-auto w-full px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-8 md:gap-12">
          {films.map((film, i) => (
            <a
              href={getLocalizedPath(`/films/${film.slug}/`, lang)}
              class="block w-fit transition-opacity duration-300"
              style={i === 0 ? "opacity:1" : "opacity:0.38"}
              data-film-link={i}
            >
              <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-tight text-white tracking-tight">
                {t(film.title, lang)}
              </h2>
              <p class="mt-2 text-sm tracking-widest uppercase text-white/60">
                {t(film.role, lang)}&ensp;·&ensp;{film.year}
              </p>
            </a>
          ))}
        </div>
      </div>
    </div>

  </div>
</BaseLayout>

<script>
  function initFilmsStage() {
    const stage = document.getElementById("films-stage");
    if (!stage) return;

    const bgs = Array.from(
      stage.querySelectorAll<HTMLElement>("[data-film-bg]"),
    );
    const links = Array.from(
      stage.querySelectorAll<HTMLElement>("[data-film-link]"),
    );

    function activate(index: number) {
      bgs.forEach((bg, i) => {
        bg.style.opacity = i === index ? "1" : "0";
      });
      links.forEach((link, i) => {
        link.style.opacity = i === index ? "1" : "0.38";
      });
    }

    links.forEach((link, i) => {
      link.addEventListener("mouseenter", () => activate(i));
    });

    // Revert to first film on leaving the stage
    stage.addEventListener("mouseleave", () => activate(0));
  }

  initFilmsStage();
  document.addEventListener("astro:after-swap", initFilmsStage);
</script>
