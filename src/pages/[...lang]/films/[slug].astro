---
/**
 * Film detail page — matches original Squarespace layout:
 * Hero (film still) → Poster + Description two-column → Video → Gallery (4-col) → Next/Prev nav
 * heroImage = film still for hero bg; coverImage = poster shown in content area.
 */
import BaseLayout from "../../../components/layout/BaseLayout.astro";
import VideoEmbed from "../../../components/ui/VideoEmbed.astro";
import { getLangFromSlug, t, getLocalizedPath, ui } from "../../../i18n";
import { films, getFilmsByOrder } from "../../../data/films";

export function getStaticPaths() {
  const paths = [];
  for (const film of films) {
    paths.push({
      params: { lang: undefined, slug: film.slug },
      props: { film },
    });
    paths.push({ params: { lang: "en", slug: film.slug }, props: { film } });
  }
  return paths;
}

const { film } = Astro.props;
const lang = getLangFromSlug(Astro.params.lang);
const title = t(film.title, lang);
const titleEN = t(film.title, "en");

/* ── Prev / Next navigation ── */
const ordered = getFilmsByOrder();
const currentIndex = ordered.findIndex((f) => f.slug === film.slug);
const prevFilm = currentIndex > 0 ? ordered[currentIndex - 1] : null;
const nextFilm = currentIndex < ordered.length - 1 ? ordered[currentIndex + 1] : null;

/* ── Poster orientation — portrait posters stay narrow, landscape gets wider ── */
const isPortraitPoster = film.slug === 'fibonacci';
---

<BaseLayout title={titleEN} lang={lang} transparentNav>
  {/* ═══════ Hero — film still as background ═══════ */}
  <section
    id="cinematic-hero"
    class="relative w-full aspect-[16/5] min-h-[300px] flex items-end overflow-hidden"
    transition:name="hero"
    transition:animate="fade"
  >
    {/* heroImage (film still) with coverImage fallback */}
    <div id="cinematic-hero-bg" class="absolute inset-0">
      <img
        src={film.heroImage || film.coverImage}
        alt=""
        class="w-full h-full object-cover"
        style={film.slug === 'meme-contaminate' ? undefined : 'transform: translateY(-20%);'}
        loading="eager"
      />
      <div
        class="absolute inset-0"
        style="background: var(--color-hero-overlay);"
      />
    </div>

    <div class="relative z-10 max-w-screen-xl mx-auto w-full px-4 sm:px-6 lg:px-8 pb-16 md:pb-20">
      <a
        href={getLocalizedPath('/films/', lang)}
        class="inline-flex items-center gap-1.5 text-sm text-white/70 hover:text-white transition-colors w-fit mb-4"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
        </svg>
        {ui('nav.films', lang)}
      </a>

      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight drop-shadow-lg">
        {title}
      </h1>
    </div>
  </section>

  <div class="relative z-10 bg-[var(--color-bg)]">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-12 space-y-16">
    {/* ═══════ Poster + Description two-column ═══════ */}
    <section class="flex flex-col md:flex-row gap-8 md:gap-12 items-start">
      {/* Poster + metadata — sticky so it stays visible while scrolling long descriptions */}
      <div class={`shrink-0 w-full mx-auto md:mx-0 md:sticky md:top-24 ${isPortraitPoster ? 'max-w-[280px] md:w-64 lg:w-72' : 'max-w-[400px] md:w-80 lg:w-96'}`}>
        <img
          src={film.posterImage}
          alt={`${titleEN} poster`}
          class="w-full"
          loading="eager"
        />
        <p class="text-center mt-4 text-sm text-[var(--color-text-secondary)]">
          {titleEN}, Film, {film.year}<br />{t(film.role, lang)}
        </p>
      </div>

      {/* Description + Synopsis + Links */}
      <div class="flex-1">
        <p class="text-xl md:text-2xl font-semibold leading-relaxed text-[var(--color-text)] mb-8">
          {t(film.description, lang)}
        </p>
        <div class="space-y-5">
          {film.synopsis.map((para) => (
            <p class="text-[var(--color-text-secondary)] text-base leading-relaxed">
              {t(para, lang)}
            </p>
          ))}
        </div>
        {film.links.gdrive && (
          <div class="flex justify-end mt-8">
            <a
              href={film.links.gdrive}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-[var(--color-bg-secondary)] hover:bg-[var(--color-surface)] text-[var(--color-text-secondary)] hover:text-[var(--color-text)] text-sm font-medium rounded-lg border border-[var(--color-border)] transition-colors"
            >
              <img src="/icons/google-drive.svg" alt="Google Drive" class="w-5 h-5" />
              {lang === "zh-cn" ? "查看 PDF" : "View PDF"}
            </a>
          </div>
        )}
      </div>
    </section>

    {/* ═══════ Video ═══════ */}
    {film.videoId && (
      <section>
        <VideoEmbed videoId={film.videoId} title={title} poster={`/images/films/${film.slug}-video-cover.png`} />
      </section>
    )}

    {/* ═══════ Gallery ═══════ */}
    {film.gallery.length > 0 && (
      <hr class="border-t border-[var(--color-border)]" />
      <section>
        <div id="film-gallery" class={`grid grid-cols-2 gap-1 ${film.gallery.length <= 12 ? 'md:grid-cols-3' : 'md:grid-cols-4'}`}>
          {film.gallery.map((src, i) => (
            <a
              href={src}
              data-pswp-width="2000"
              data-pswp-height="2000"
              class="group relative block overflow-hidden cursor-zoom-in"
            >
              <img
                src={src}
                alt={`${titleEN} still ${i + 1}`}
                class="w-full aspect-video object-cover transition-transform duration-[400ms] group-hover:scale-[1.03]"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/35 transition-colors duration-[400ms] flex items-center justify-center">
                <svg
                  class="w-10 h-10 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-[400ms] drop-shadow-lg"
                  fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0zm0 0v.01M11 8v6m-3-3h6" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {/* ═══════ Prev / Next navigation ═══════ */}
    <nav class="flex items-center justify-between pt-8">
      {prevFilm ? (
        <a
          href={getLocalizedPath(`/films/${prevFilm.slug}/`, lang)}
          class="group flex items-center gap-2 text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors"
        >
          <svg class="w-5 h-5 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
          </svg>
          <span class="text-lg md:text-xl italic">{t(prevFilm.title, lang)}</span>
        </a>
      ) : (
        <div />
      )}

      {nextFilm ? (
        <a
          href={getLocalizedPath(`/films/${nextFilm.slug}/`, lang)}
          class="group flex items-center gap-2 text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors"
        >
          <span class="text-lg md:text-xl italic">{t(nextFilm.title, lang)}</span>
          <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      ) : (
        <div />
      )}
    </nav>
  </div>
  </div>
</BaseLayout>

<script>
  import PhotoSwipeLightbox from "photoswipe/lightbox";
  import PhotoSwipe from "photoswipe";
  import { addThumbnailStrip } from "../../../utils/pswp-thumbnails";

  function initGallery() {
    const gallery = document.querySelector<HTMLElement>("#film-gallery");
    if (!gallery) return;

    const lightbox = new PhotoSwipeLightbox({
      gallery,
      children: "a",
      pswpModule: PhotoSwipe,
    });

    gallery.querySelectorAll<HTMLAnchorElement>("a").forEach((link) => {
      const img = link.querySelector("img");
      if (!img) return;
      const update = () => {
        if (img.naturalWidth > 0) {
          link.setAttribute("data-pswp-width", String(img.naturalWidth));
          link.setAttribute("data-pswp-height", String(img.naturalHeight));
        }
      };
      if (img.complete && img.naturalWidth > 0) {
        update();
      } else {
        img.addEventListener("load", update);
      }
    });

    // At click time, read actual image dimensions (fixes first-click-before-load issue)
    lightbox.addFilter('domItemData', (itemData, element, linkEl) => {
      const img = linkEl.querySelector('img');
      if (img && img.naturalWidth > 0) {
        itemData.w = img.naturalWidth;
        itemData.h = img.naturalHeight;
      }
      return itemData;
    });

    addThumbnailStrip(lightbox, gallery, "a");
    lightbox.init();
    document.addEventListener("astro:before-swap", () => lightbox.destroy(), {
      once: true,
    });
  }

  initGallery();
  document.addEventListener("astro:after-swap", initGallery);

  /* ── Cinematic hero scroll-driven fade ── */
  function initCinematicHero() {
    const section = document.getElementById("cinematic-hero");
    const bgLayer = document.getElementById("cinematic-hero-bg");
    if (!section || !bgLayer) return;

    function update() {
      const rect = section.getBoundingClientRect();
      const heroH = section.offsetHeight;
      const scrolledPast = -rect.top;

      if (rect.bottom <= 0) {
        bgLayer.style.cssText = "position:absolute;opacity:0;";
      } else {
        bgLayer.style.position = "fixed";
        bgLayer.style.top = "0";
        bgLayer.style.left = "0";
        bgLayer.style.width = "100%";
        bgLayer.style.height = `${heroH}px`;
        bgLayer.style.zIndex = "0";
        const fade = Math.max(0, scrolledPast) / (heroH * 0.65);
        bgLayer.style.opacity = String(Math.max(0, 1 - fade));
      }
    }

    window.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", update, { passive: true });
    update();

    document.addEventListener(
      "astro:before-swap",
      () => {
        window.removeEventListener("scroll", update);
        window.removeEventListener("resize", update);
        bgLayer.style.cssText = "";
      },
      { once: true }
    );
  }

  initCinematicHero();
  document.addEventListener("astro:after-swap", initCinematicHero);
</script>
