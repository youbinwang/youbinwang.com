---
/**
 * Film detail page — hero + poster/description + synopsis + gallery.
 * Layout mirrors the original Squarespace site design.
 */
import BaseLayout from "../../../components/layout/BaseLayout.astro";
import VideoEmbed from "../../../components/ui/VideoEmbed.astro";
import { getLangFromSlug, t, getLocalizedPath } from "../../../i18n";
import { films } from "../../../data/films";

export function getStaticPaths() {
  const paths = [];
  for (const film of films) {
    paths.push({
      params: { lang: undefined, slug: film.slug },
      props: { film },
    });
    paths.push({ params: { lang: "en", slug: film.slug }, props: { film } });
  }
  return paths;
}

const { film } = Astro.props;
const lang = getLangFromSlug(Astro.params.lang);
const title = t(film.title, lang);
const titleEN = t(film.title, "en");
---

<BaseLayout title={titleEN} lang={lang} transparentNav>
  {/* ═══════ Hero ═══════ */}
  <section
    class="relative w-full min-h-[50vh] flex items-end overflow-hidden"
    transition:name="hero"
    transition:animate="fade"
  >
    {/* Background */}
    {
      film.heroImage ? (
        <div class="absolute inset-0">
          <img
            src={film.heroImage}
            alt=""
            class="w-full h-full object-cover"
            loading="eager"
          />
          <div
            class="absolute inset-0"
            style="background: var(--color-hero-overlay);"
          />
        </div>
      ) : (
        <div class="absolute inset-0 bg-bg" />
      )
    }

    {/* Title */}
    <div class="relative z-10 max-w-screen-xl mx-auto w-full px-4 sm:px-6 lg:px-8 pb-10">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white tracking-tight drop-shadow-lg">
        {title}
      </h1>
    </div>
  </section>

  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-12">
    {/* ═══════ Back link + Meta ═══════ */}
    <div>
      <a
        href={getLocalizedPath("/films/", lang)}
        class="inline-flex items-center gap-1 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors mb-4"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        {lang === "zh-cn" ? "返回电影列表" : "Back to Films"}
      </a>
      <p class="text-sm tracking-widest uppercase text-[var(--color-text-muted)]">
        {lang === "zh-cn" ? "电影" : "Film"}&ensp;·&ensp;{film.year}&ensp;·&ensp;{t(film.role, lang)}
      </p>
    </div>

    {/* ═══════ Featured: Poster + Description ═══════ */}
    <section class="flex flex-col md:flex-row gap-8 md:gap-12 items-start">
      {/* Poster */}
      <div class="shrink-0 w-full md:w-72 lg:w-80">
        <img
          src={film.coverImage}
          alt={`${titleEN} poster`}
          class="w-full rounded-lg shadow-lg"
          loading="eager"
        />
      </div>

      {/* Description — displayed as a prominent logline */}
      <div class="flex-1 flex items-center">
        <p class="text-xl md:text-2xl lg:text-[1.75rem] font-medium leading-relaxed text-[var(--color-text)]">
          {t(film.description, lang)}
        </p>
      </div>
    </section>

    {/* ═══════ Synopsis ═══════ */}
    {film.synopsis.length > 0 && (
      <section class="max-w-4xl space-y-6">
        {film.synopsis.map((para) => (
          <p class="text-[var(--color-text-secondary)] text-base leading-relaxed">
            {t(para, lang)}
          </p>
        ))}
      </section>
    )}

    {/* ═══════ Video ═══════ */}
    {film.videoId && (
      <section>
        <VideoEmbed videoId={film.videoId} title={title} />
      </section>
    )}

    {/* ═══════ Gallery ═══════ */}
    {film.gallery.length > 0 && (
      <section>
        <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-text)] mb-6">
          {lang === "zh-cn" ? "剧照" : "Stills"}
        </h2>
        <div id="film-gallery" class="grid grid-cols-2 md:grid-cols-3 gap-3">
          {film.gallery.map((src, i) => (
            <a
              href={src}
              data-pswp-width="2000"
              data-pswp-height="2000"
              class="group relative block overflow-hidden rounded-lg cursor-zoom-in"
            >
              <img
                src={src}
                alt={`${titleEN} still ${i + 1}`}
                class="w-full aspect-video object-cover transition-transform duration-[400ms] group-hover:scale-[1.03]"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/35 transition-colors duration-[400ms] flex items-center justify-center">
                <svg
                  class="w-10 h-10 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-[400ms] drop-shadow-lg"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0zm0 0v.01M11 8v6m-3-3h6" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {/* ═══════ Links ═══════ */}
    {film.links.gdrive && (
      <section>
        <a
          href={film.links.gdrive}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-[var(--color-bg-secondary)] hover:bg-[var(--color-surface)] text-[var(--color-text-secondary)] hover:text-[var(--color-text)] text-sm font-medium rounded-lg border border-[var(--color-border)] transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M7.71 3.5L1.15 15l4.58 7.5h13.54l4.58-7.5L17.29 3.5H7.71zm.58 1h8.42l5.92 10.5H2.37L8.29 4.5zM5.27 16h13.46l-3.92 6.5H9.19L5.27 16z" />
          </svg>
          {lang === "zh-cn" ? "在 Google Drive 查看" : "View on Google Drive"}
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </section>
    )}
  </div>
</BaseLayout>

<script>
  import PhotoSwipeLightbox from "photoswipe/lightbox";
  import PhotoSwipe from "photoswipe";

  function initGallery() {
    const gallery = document.querySelector<HTMLElement>("#film-gallery");
    if (!gallery) return;

    const lightbox = new PhotoSwipeLightbox({
      gallery,
      children: "a",
      pswpModule: PhotoSwipe,
    });

    gallery.querySelectorAll<HTMLAnchorElement>("a").forEach((link) => {
      const img = link.querySelector("img");
      if (!img) return;
      const update = () => {
        if (img.naturalWidth > 0) {
          link.setAttribute("data-pswp-width", String(img.naturalWidth));
          link.setAttribute("data-pswp-height", String(img.naturalHeight));
        }
      };
      if (img.complete && img.naturalWidth > 0) {
        update();
      } else {
        img.addEventListener("load", update);
      }
    });

    lightbox.init();
    document.addEventListener("astro:before-swap", () => lightbox.destroy(), {
      once: true,
    });
  }

  initGallery();
  document.addEventListener("astro:after-swap", initGallery);
</script>
