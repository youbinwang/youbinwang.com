---
/**
 * Film detail page — matches original Squarespace layout:
 * Hero (film still) → Poster + Description two-column → Video → Gallery (4-col) → Next/Prev nav
 * heroImage = film still for hero bg; coverImage = poster shown in content area.
 */
import BaseLayout from "../../../components/layout/BaseLayout.astro";
import VideoEmbed from "../../../components/ui/VideoEmbed.astro";
import { getLangFromSlug, t, getLocalizedPath } from "../../../i18n";
import { films, getFilmsByOrder } from "../../../data/films";

export function getStaticPaths() {
  const paths = [];
  for (const film of films) {
    paths.push({
      params: { lang: undefined, slug: film.slug },
      props: { film },
    });
    paths.push({ params: { lang: "en", slug: film.slug }, props: { film } });
  }
  return paths;
}

const { film } = Astro.props;
const lang = getLangFromSlug(Astro.params.lang);
const title = t(film.title, lang);
const titleEN = t(film.title, "en");

/* ── Prev / Next navigation ── */
const ordered = getFilmsByOrder();
const currentIndex = ordered.findIndex((f) => f.slug === film.slug);
const prevFilm = currentIndex > 0 ? ordered[currentIndex - 1] : null;
const nextFilm = currentIndex < ordered.length - 1 ? ordered[currentIndex + 1] : null;
---

<BaseLayout title={titleEN} lang={lang} transparentNav>
  {/* ═══════ Hero — film still as background ═══════ */}
  <section
    class="relative w-full min-h-[50vh] flex items-end overflow-hidden"
    transition:name="hero"
    transition:animate="fade"
  >
    {/* heroImage (film still) with coverImage fallback */}
    <div class="absolute inset-0">
      <img
        src={film.heroImage || film.coverImage}
        alt=""
        class="w-full h-full object-cover"
        style="transform: translateY(-20%);"
        loading="eager"
      />
      <div
        class="absolute inset-0"
        style="background: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.4) 60%, rgba(0,0,0,0.65) 100%);"
      />
    </div>

    <div class="relative z-10 max-w-screen-xl mx-auto w-full px-4 sm:px-6 lg:px-8 pb-10">
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight drop-shadow-lg">
        {title}
      </h1>
    </div>
  </section>

  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-12">
    {/* ═══════ Poster + Description two-column ═══════ */}
    <section class="flex flex-col md:flex-row gap-8 md:gap-12 items-start">
      {/* Poster + metadata */}
      <div class="shrink-0 w-full max-w-[280px] mx-auto md:mx-0 md:w-64 lg:w-72">
        <img
          src={film.posterImage}
          alt={`${titleEN} poster`}
          class="w-full"
          loading="eager"
        />
        <div class="text-center mt-4 space-y-0.5">
          <p class="text-sm text-[var(--color-text)]">
            {titleEN}, Film, {film.year}
          </p>
          <p class="text-sm text-[var(--color-text)]">
            {t(film.role, lang)}
          </p>
        </div>
      </div>

      {/* Description + Synopsis */}
      <div class="flex-1 space-y-6">
        <p class="text-xl md:text-2xl font-semibold leading-relaxed text-[var(--color-text)]">
          {t(film.description, lang)}
        </p>
        {film.synopsis.map((para) => (
          <p class="text-[var(--color-text-secondary)] text-base leading-relaxed">
            {t(para, lang)}
          </p>
        ))}
      </div>
    </section>

    {/* ═══════ Video ═══════ */}
    {film.videoId && (
      <section>
        <VideoEmbed videoId={film.videoId} title={title} />
      </section>
    )}

    {/* ═══════ Gallery ═══════ */}
    {film.gallery.length > 0 && (
      <section>
        <div id="film-gallery" class={`grid grid-cols-2 gap-1 ${film.gallery.length <= 12 ? 'md:grid-cols-3' : 'md:grid-cols-4'}`}>
          {film.gallery.map((src, i) => (
            <a
              href={src}
              data-pswp-width="2000"
              data-pswp-height="2000"
              class="block overflow-hidden cursor-zoom-in"
            >
              <img
                src={src}
                alt={`${titleEN} still ${i + 1}`}
                class="w-full aspect-video object-cover"
                loading="lazy"
              />
            </a>
          ))}
        </div>
      </section>
    )}

    {/* ═══════ Links ═══════ */}
    {film.links.gdrive && (
      <section>
        <a
          href={film.links.gdrive}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-[var(--color-bg-secondary)] hover:bg-[var(--color-surface)] text-[var(--color-text-secondary)] hover:text-[var(--color-text)] text-sm font-medium rounded-lg border border-[var(--color-border)] transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M7.71 3.5L1.15 15l4.58 7.5h13.54l4.58-7.5L17.29 3.5H7.71zm.58 1h8.42l5.92 10.5H2.37L8.29 4.5zM5.27 16h13.46l-3.92 6.5H9.19L5.27 16z" />
          </svg>
          {lang === "zh-cn" ? "在 Google Drive 查看" : "View on Google Drive"}
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </section>
    )}

    {/* ═══════ Prev / Next navigation ═══════ */}
    <nav class="flex items-center justify-between pt-8">
      {prevFilm ? (
        <a
          href={getLocalizedPath(`/films/${prevFilm.slug}/`, lang)}
          class="group flex items-center gap-2 text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors"
        >
          <svg class="w-5 h-5 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
          </svg>
          <span class="text-lg md:text-xl italic">{t(prevFilm.title, lang)}</span>
        </a>
      ) : (
        <div />
      )}

      {nextFilm ? (
        <a
          href={getLocalizedPath(`/films/${nextFilm.slug}/`, lang)}
          class="group flex items-center gap-2 text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors"
        >
          <span class="text-lg md:text-xl italic">{t(nextFilm.title, lang)}</span>
          <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      ) : (
        <div />
      )}
    </nav>
  </div>
</BaseLayout>

<script>
  import PhotoSwipeLightbox from "photoswipe/lightbox";
  import PhotoSwipe from "photoswipe";

  function initGallery() {
    const gallery = document.querySelector<HTMLElement>("#film-gallery");
    if (!gallery) return;

    const lightbox = new PhotoSwipeLightbox({
      gallery,
      children: "a",
      pswpModule: PhotoSwipe,
    });

    gallery.querySelectorAll<HTMLAnchorElement>("a").forEach((link) => {
      const img = link.querySelector("img");
      if (!img) return;
      const update = () => {
        if (img.naturalWidth > 0) {
          link.setAttribute("data-pswp-width", String(img.naturalWidth));
          link.setAttribute("data-pswp-height", String(img.naturalHeight));
        }
      };
      if (img.complete && img.naturalWidth > 0) {
        update();
      } else {
        img.addEventListener("load", update);
      }
    });

    lightbox.init();
    document.addEventListener("astro:before-swap", () => lightbox.destroy(), {
      once: true,
    });
  }

  initGallery();
  document.addEventListener("astro:after-swap", initGallery);
</script>
