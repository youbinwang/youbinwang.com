---
/**
 * Games list page — spacious vertical layout grouped by category.
 * Each project: video/cover on left, info + action buttons on right.
 * At xl (1440px+): fixed floating TOC panel on the right side for category navigation.
 */
import BaseLayout from "../../../components/layout/BaseLayout.astro";
import HeroSection from "../../../components/layout/HeroSection.astro";
import VideoEmbed from "../../../components/ui/VideoEmbed.astro";
import { getLangFromSlug, getI18nStaticPaths, ui, t, getLocalizedPath } from "../../../i18n";
import { getGamesByCategory } from "../../../data/games";
import type { GameProject } from "../../../data/games";

export const getStaticPaths = getI18nStaticPaths;

const lang = getLangFromSlug(Astro.params.lang);

/** Category order: 玩法/战斗/关卡 → 研发制作人 → 个人独立 → 其他 */
const categories: { key: GameProject["category"]; label: string }[] = [
  { key: "combat-level", label: ui("games.category.combat-level", lang) },
  { key: "producer", label: ui("games.category.producer", lang) },
  { key: "personal", label: ui("games.category.personal", lang) },
  { key: "gameplay", label: ui("games.category.gameplay", lang) },
];

/** TOC items — only categories with at least one game */
const tocItems = categories.filter(({ key }) => getGamesByCategory(key).length > 0);

/** Compute human-readable duration from "Mon YYYY - Mon YYYY" format */
function getDurationLabel(durationEn: string, isZh: boolean): string | null {
  const match = durationEn.match(/^([A-Z][a-z]{2})\s+(\d{4})\s*-\s*([A-Z][a-z]{2})\s+(\d{4})$/);
  if (!match) return null;
  const m: Record<string, number> = {
    Jan:1,Feb:2,Mar:3,Apr:4,May:5,Jun:6,Jul:7,Aug:8,Sep:9,Oct:10,Nov:11,Dec:12
  };
  const diff = (parseInt(match[4]) - parseInt(match[2])) * 12 + (m[match[3]] - m[match[1]]) + 1;
  return isZh ? `${diff} 个月` : diff === 1 ? '1 month' : `${diff} months`;
}
---

<BaseLayout title={ui("games.title", lang)} lang={lang} transparentNav>
  {/* Banner */}
  <HeroSection
    backgroundImage="/images/games/games-hero.png"
    title={ui("games.title", lang)}
    subtitle={lang === "zh-cn"
      ? "玩法 / 战斗 / 关卡设计"
      : "Gameplay / Combat / Level Designer"}
  />

  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div>

      {/* ── Category Sections (main content) ── */}
      <div id="games-main" class="space-y-28">
        {
          categories.map(({ key, label }) => {
            const categoryGames = getGamesByCategory(key);
            if (categoryGames.length === 0) return null;
            return (
              <section id={`section-${key}`} class="scroll-mt-24">
                {/* Category heading */}
                <h2 class="text-3xl font-bold text-[var(--color-text)] mb-14 pb-4 border-b-2 border-[var(--color-border)]">
                  {label}
                </h2>

                <div class="space-y-24">
                  {categoryGames.map((game) => {
                    const href = getLocalizedPath(`/games/${game.slug}/`, lang);

                    return (
                      <article id={`project-${game.slug}`} class="flex flex-col lg:flex-row gap-10 xl:gap-14 items-start scroll-mt-24">
                        {/* ── Left: Video or Cover Image ── */}
                        <div class="w-full lg:w-[55%] flex-shrink-0">
                          {game.videoId ? (
                            <VideoEmbed
                              videoId={game.videoId}
                              title={t(game.title, lang)}
                              poster={game.coverImage}
                            />
                          ) : (
                            <a
                              href={href}
                              class="group block overflow-hidden rounded-lg"
                            >
                              <img
                                src={game.coverImage}
                                alt={t(game.title, lang)}
                                class="w-full aspect-video object-cover transition-transform duration-500 group-hover:scale-105"
                                loading="lazy"
                              />
                            </a>
                          )}
                        </div>

                        {/* ── Right: Project Info ── */}
                        <div class="w-full lg:w-[45%] flex flex-col lg:pt-[10%]">

                          {/* Title */}
                          <a href={href} class="group">
                            <h3 class="text-xl lg:text-2xl font-bold text-[var(--color-text)] mb-3 group-hover:text-[var(--color-accent)] transition-colors">
                              {t(game.title, lang)}
                            </h3>
                          </a>

                          {/* 4 Tag pills */}
                          <div class="flex flex-wrap gap-2 mb-6">
                            {[game.tags.genre, game.tags.engine, game.tags.discipline, game.tags.scope].map((tag) => (
                              <span class="px-2.5 py-0.5 text-xs font-medium rounded-full border border-[var(--color-border)] text-[var(--color-text-secondary)]">
                                {tag}
                              </span>
                            ))}
                          </div>

                          {/* Meta info: labeled grid */}
                          <dl class="meta-grid mb-10">
                            <dt>Role</dt>
                            <dd>{t(game.meta.role, lang)}</dd>
                            <dt>Duration</dt>
                            <dd>
                              {(() => {
                                const label = getDurationLabel(game.meta.duration.en, lang === 'zh-cn');
                                const full = t(game.meta.duration, lang);
                                return label ? <>{label}（{full}）</> : <>{full}</>;
                              })()}
                            </dd>
                          </dl>

                          {/* Action buttons */}
                          <div class="flex flex-wrap items-center gap-3">
                            {/* Primary CTA — internal page navigation */}
                            <a
                              href={href}
                              class="inline-flex items-center gap-2 px-5 py-2.5 bg-[var(--color-accent)] text-white text-sm font-semibold rounded-full hover:opacity-90 transition-opacity"
                            >
                              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                                <circle cx="12" cy="12" r="9" />
                                <path stroke-linecap="round" d="M12 8v8M8 12h8" />
                              </svg>
                              {ui('game.details', lang)}
                            </a>

                            {/* Secondary — external links (outlined) */}
                            {game.links.youtube && (
                              <a
                                href={game.links.youtube}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 px-5 py-2.5 border border-[#FF0000] text-[#FF0000] text-sm font-medium rounded-full hover:bg-[#FF0000] hover:text-white transition-colors"
                              >
                                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                  <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
                                </svg>
                                {ui('game.trialVideo', lang)}
                              </a>
                            )}

                            {game.links.gdrive && game.links.gdrive.length > 0 && (
                              <a
                                href={game.links.gdrive[0]}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 px-5 py-2.5 border border-[#35A852] text-[#35A852] text-sm font-medium rounded-full hover:bg-[#35A852] hover:text-white transition-colors"
                              >
                                <svg class="w-4 h-4" viewBox="0 0 87.3 78" xmlns="http://www.w3.org/2000/svg">
                                  <path d="m6.6 66.85 3.85 6.65c.8 1.4 1.95 2.5 3.3 3.3l13.75-23.8H0c0 1.55.4 3.1 1.2 4.5z" fill="#0066DA" />
                                  <path d="m43.65 25-13.75-23.8c-1.35.8-2.5 1.9-3.3 3.3l-25.4 44a9.06 9.06 0 0 0-1.2 4.5h27.5z" fill="#00AC47" />
                                  <path d="M73.55 76.8c1.35-.8 2.5-1.9 3.3-3.3l1.6-2.75 7.65-13.25c.8-1.4 1.2-2.95 1.2-4.5H59.85L73.55 76.8z" fill="#EA4335" />
                                  <path d="M43.65 25 57.4 1.2C56.05.4 54.5 0 52.9 0H34.4c-1.6 0-3.15.45-4.5 1.2z" fill="#00832D" />
                                  <path d="M59.85 53H27.5L13.75 76.8c1.35.8 2.9 1.2 4.5 1.2h36.75c1.6 0 3.15-.45 4.5-1.2z" fill="#2684FC" />
                                  <path d="M73.4 26.5 60.65 4.5c-.8-1.4-1.95-2.5-3.3-3.3L43.6 25l16.25 28h27.5c0-1.55-.4-3.1-1.2-4.5z" fill="#FFBA00" />
                                </svg>
                                {ui('game.designDocs', lang)}
                              </a>
                            )}

                            {game.links.itch && (
                              <a href={game.links.itch} target="_blank" rel="noopener noreferrer"
                                class="group inline-flex items-center gap-2 px-5 py-2.5 border border-[#FA5C5C] text-[#FA5C5C] text-sm font-medium rounded-full hover:bg-[#FA5C5C] hover:text-white transition-colors">
                                <img src="/icons/itch-io.svg" alt="" class="w-4 h-4 [filter:brightness(0)_saturate(100%)_invert(54%)_sepia(83%)_saturate(504%)_hue-rotate(314deg)] group-hover:filter-none transition-all" aria-hidden="true" />
                                itch.io
                              </a>
                            )}

                            {game.links.steam && (
                              <a href={game.links.steam} target="_blank" rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 px-5 py-2.5 border border-[#1b2838] text-[#1b2838] text-sm font-medium rounded-full hover:bg-[#1b2838] hover:text-white transition-colors">
                                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                  <path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.029 4.524 4.524s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.606 0 11.979 0zM7.54 18.21l-1.473-.61c.262.543.714.999 1.314 1.25 1.297.539 2.793-.076 3.332-1.375.263-.63.264-1.319.005-1.949s-.75-1.121-1.38-1.383c-.624-.26-1.29-.249-1.878-.03l1.523.63c.956.4 1.409 1.5 1.009 2.455-.397.957-1.497 1.41-2.452 1.012H7.54zm11.415-9.303c0-1.662-1.353-3.015-3.015-3.015-1.665 0-3.015 1.353-3.015 3.015 0 1.665 1.35 3.015 3.015 3.015 1.662 0 3.015-1.35 3.015-3.015zm-5.273.016c0-1.252 1.013-2.266 2.265-2.266 1.249 0 2.266 1.014 2.266 2.266 0 1.251-1.017 2.265-2.266 2.265-1.252 0-2.265-1.014-2.265-2.265z"/>
                                </svg>
                                Steam
                              </a>
                            )}
                          </div>

                        </div>
                      </article>
                    );
                  })}
                </div>
              </section>
            );
          })
        }
      </div>

    </div>
  </div>

  {/* ── Fixed floating TOC panel (xl+ only) ── */}
  <nav
    id="games-toc"
    aria-label={lang === "zh-cn" ? "分类导航" : "Category navigation"}
  >
    <p class="toc-heading">
      {lang === "zh-cn" ? "目录" : "Contents"}
    </p>
    <ul class="toc-list">
      {tocItems.map(({ key, label }) => {
        const categoryGames = getGamesByCategory(key);
        return (
          <li class="toc-group">
            <a
              href={`#section-${key}`}
              class="toc-category"
            >
              {label}
            </a>
            <ul class="toc-projects">
              {categoryGames.map((game) => (
                <li>
                  <a
                    href={`#project-${game.slug}`}
                    class="toc-item"
                    data-section={`project-${game.slug}`}
                  >
                    {t(game.title, lang)}
                  </a>
                </li>
              ))}
            </ul>
          </li>
        );
      })}
    </ul>
  </nav>
</BaseLayout>

<style>
  /* ─── Fixed floating TOC panel ─────────────────────────── */
  #games-toc {
    display: none;
    position: fixed;
    right: max(0px, calc((100vw - 90rem) / 2 - 12rem));
    top: 7rem;
    width: 12rem;
    z-index: 20;

    background: color-mix(in srgb, var(--color-surface) 88%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1rem 1.125rem;
    box-shadow:
      0 4px 16px color-mix(in srgb, var(--color-text) 6%, transparent),
      0 1px 4px  color-mix(in srgb, var(--color-text) 4%, transparent);

    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  /* Show at 114rem (1824px): TOC left edge = content right edge at this width */
  @media (min-width: 114rem) {
    #games-toc {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
  }

  #games-toc.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  /* ─── Meta labeled grid ──────────────────────────────── */
  .meta-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.45rem 1rem;
    margin: 0;
  }

  .meta-grid dt {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding-top: 0.1rem; /* optical alignment with dd */
  }

  .meta-grid dd {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  /* "Contents / 目录" label */
  .toc-heading {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 0.5rem;
  }

  /* Top-level list */
  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* Category group */
  .toc-group {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  /* Category label — not a scrollspy target, just a jump link */
  .toc-category {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.1rem 0;
    transition: color 150ms ease;
  }

  .toc-category:hover {
    color: var(--color-text-secondary);
  }

  /* Project sub-list */
  .toc-projects {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
  }

  /* Project name link */
  .toc-item {
    display: block;
    font-size: 0.8125rem;
    line-height: 1.35;
    color: var(--color-text-secondary);
    padding: 0.3rem 0.625rem;
    margin-left: -1px;
    border-left: 2px solid transparent;
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 150ms ease, border-color 150ms ease;
  }

  .toc-item:hover {
    color: var(--color-accent);
    border-left-color: color-mix(in srgb, var(--color-accent) 35%, transparent);
  }

  .toc-item.is-active {
    color: var(--color-accent);
    font-weight: 600;
    border-left-color: var(--color-accent);
  }
</style>

<script>
  function initGamesTOC() {
    const toc = document.getElementById("games-toc");
    if (!toc) return;

    const tocLinks = toc.querySelectorAll<HTMLAnchorElement>("a[data-section]");
    if (!tocLinks.length) return;

    type SectionEntry = { link: HTMLAnchorElement; section: HTMLElement };

    const sections: SectionEntry[] = [...tocLinks]
      .map((link) => ({
        link,
        section: document.getElementById(link.dataset.section!),
      }))
      .filter((item): item is SectionEntry => item.section !== null);

    if (!sections.length) return;

    // ── Scrollspy: highlight active project ──────────────────
    function setActive(target: HTMLElement) {
      tocLinks.forEach((l) => l.classList.remove("is-active"));
      const match = sections.find(({ section }) => section === target);
      if (match) match.link.classList.add("is-active");
    }

    function syncActive() {
      const midpoint = window.scrollY + window.innerHeight * 0.3;
      let active = sections[0].section;
      for (const { section } of sections) {
        if (section.getBoundingClientRect().top + window.scrollY <= midpoint) {
          active = section;
        }
      }
      setActive(active);
    }
    syncActive();

    const scrollSpyObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target as HTMLElement);
            break;
          }
        }
      },
      { rootMargin: "-80px 0px -60% 0px", threshold: 0 }
    );
    sections.forEach(({ section }) => scrollSpyObserver.observe(section));

    // ── Show/hide: fade in after scrolling past the hero ─────
    function updateVisibility() {
      const threshold = window.innerHeight * 0.4;
      toc.classList.toggle("is-visible", window.scrollY > threshold);
    }
    updateVisibility();
    window.addEventListener("scroll", updateVisibility, { passive: true });

    // ── Cleanup on View Transitions ──────────────────────────
    document.addEventListener(
      "astro:before-swap",
      () => {
        scrollSpyObserver.disconnect();
        window.removeEventListener("scroll", updateVisibility);
      },
      { once: true }
    );
  }

  initGamesTOC();
  document.addEventListener("astro:after-swap", initGamesTOC);
</script>
