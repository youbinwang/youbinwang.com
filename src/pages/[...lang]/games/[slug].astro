---
/**
 * Game overview page — redesigned layout:
 * Hero (tags + title) → Video → Meta blocks → Description → Links → Screenshots (horizontal scroll) → Details
 * Details logic: tech-docs → CTA link to Starlight docs, key-features → inline MDX content.
 */
import BaseLayout from "../../../components/layout/BaseLayout.astro";
import VideoEmbed from "../../../components/ui/VideoEmbed.astro";
import ImageGallery from "../../../components/ui/ImageGallery.tsx";
import ImageCarousel from "../../../components/ui/ImageCarousel.tsx";
import { getLangFromSlug, t, getLocalizedPath, ui, uiEN } from "../../../i18n";
import { games } from "../../../data/games";
import { getEntry, render } from "astro:content";

export function getStaticPaths() {
  const paths = [];
  for (const game of games) {
    paths.push({
      params: { lang: undefined, slug: game.slug },
      props: { game },
    });
    paths.push({ params: { lang: "en", slug: game.slug }, props: { game } });
  }
  return paths;
}

const { game } = Astro.props;
const lang = getLangFromSlug(Astro.params.lang);
const title = t(game.title, lang);
const titleEN = t(game.title, "en");

/* ── Meta items (labels always English) ── */
const metaItems = [
  { label: "ROLE", value: t(game.meta.role, lang) },
  { label: "ENGINE", value: game.meta.engine },
  { label: "PLATFORM", value: game.meta.platform },
  { label: "TEAM SIZE", value: t(game.meta.teamSize, lang) },
  { label: "DURATION", value: t(game.meta.duration, lang) },
];

/* ── Hero tags (genre, engine, discipline, scope) ── */
const heroTags = [
  game.tags.genre,
  game.tags.engine,
  game.tags.discipline,
  game.tags.scope,
];

/* ── External links ── */
const externalLinks: { label: string; href: string }[] = [];
if (game.links.itch)
  externalLinks.push({ label: "itch.io", href: game.links.itch });
if (game.links.steam)
  externalLinks.push({ label: "Steam", href: game.links.steam });
if (game.links.youtube)
  externalLinks.push({ label: "YouTube", href: game.links.youtube });
if (game.links.gdrive) {
  game.links.gdrive.forEach((url, i) => {
    externalLinks.push({
      label: `Google Drive${game.links.gdrive!.length > 1 ? ` ${i + 1}` : ""}`,
      href: url,
    });
  });
}
if (game.links.github)
  externalLinks.push({ label: "GitHub", href: game.links.github });

/* ── Docs: tech-docs → CTA, key-features → inline MDX ── */
const techDocsHref =
  game.docsType === "tech-docs"
    ? lang === "en"
      ? `/en/docs/${game.slug}/`
      : `/docs/${game.slug}/`
    : null;

let DetailsContent: any = null;
if (game.docsType === "key-features") {
  const entryId = lang === "en" ? `en/docs/${game.slug}` : `docs/${game.slug}`;
  try {
    const entry = await getEntry("docs", entryId);
    if (entry) {
      const rendered = await render(entry);
      DetailsContent = rendered.Content;
    }
  } catch {
    /* MDX not found — skip inline details */
  }
}
---

<BaseLayout title={titleEN} lang={lang} transparentNav>
  {/* ═══════ Hero with tags & title ═══════ */}
  <section
    id="cinematic-hero"
    class="relative w-full aspect-[16/5] min-h-[300px] flex items-end overflow-hidden"
    transition:name="hero"
    transition:animate="fade"
  >
    {/* Background */}
    {
      game.heroImage ? (
        <div id="cinematic-hero-bg" class="absolute inset-0">
          <div
            class="absolute inset-0 bg-cover"
            style={`background-image: url('${game.heroImage}'); background-position: ${game.heroPosition ?? '50% 50%'};`}
          />
          <div
            class="absolute inset-0"
            style="background: var(--color-hero-overlay);"
          />
        </div>
      ) : (
        <div id="cinematic-hero-bg" class="absolute inset-0 bg-bg" />
      )
    }

    {/* Tags + Title */}
    <div
      class="relative z-10 max-w-screen-xl mx-auto w-full px-4 sm:px-6 lg:px-8 pb-16 md:pb-20"
    >
      <a
        href={getLocalizedPath('/games/', lang)}
        class="inline-flex items-center gap-1.5 text-sm text-white/70 hover:text-white transition-colors w-fit mb-4"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
        </svg>
        {ui('nav.games', lang)}
      </a>
      <div class="flex flex-wrap gap-2 mb-4">
        {
          heroTags.map((tag) => (
            <span class="inline-block px-3 py-1 text-xs font-medium rounded-full bg-white/20 text-white backdrop-blur-sm border border-white/20">
              {tag}
            </span>
          ))
        }
      </div>
      <h1
        class="text-3xl sm:text-4xl md:text-5xl font-bold text-white tracking-tight drop-shadow-lg"
      >
        {title}
      </h1>
    </div>
  </section>

  <div class="relative z-10 bg-[var(--color-bg)]">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-10">
    {/* ═══════ Video ═══════ */}
    {
      game.videoId && (
        <section>
          <VideoEmbed videoId={game.videoId} title={title} />
        </section>
      )
    }

    {/* ═══════ Meta info blocks ═══════ */}
    <dl class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
      {
        metaItems.map(({ label, value }) => (
          <div class="border border-[var(--color-border)] rounded-lg px-4 py-4 text-center bg-[var(--color-bg-secondary)]">
            <dt class="text-[11px] uppercase tracking-widest text-[var(--color-text-muted)] mb-1.5">
              {label}
            </dt>
            <dd class="text-sm text-[var(--color-text)] leading-snug">
              {value}
            </dd>
          </div>
        ))
      }
    </dl>

    {/* ═══════ Separator ═══════ */}
    <hr class="border-[var(--color-border)]" />

    {/* ═══════ Description ═══════ */}
    <section>
      <p class="text-[var(--color-text)] text-base leading-relaxed max-w-3xl">
        {t(game.description, lang)}
      </p>
    </section>

    {/* ═══════ External links ═══════ */}
    {
      externalLinks.length > 0 && (
        <section class="flex flex-wrap items-center gap-3">
          {externalLinks.map(({ label, href }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 bg-[var(--color-bg-secondary)] hover:bg-[var(--color-bg-tertiary)] text-[var(--color-text-secondary)] hover:text-[var(--color-text)] text-sm rounded-lg border border-[var(--color-border)] transition-colors"
            >
              {label}
              <svg
                class="w-3 h-3"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                />
              </svg>
            </a>
          ))}
        </section>
      )
    }

    {/* ═══════ Screenshots / Slides ═══════ */}
    {
      game.gallery.length > 0 && (
        <section>
          <h2 class="text-lg font-semibold text-[var(--color-text)] mb-4">
            {game.slug === "elemental-realm"
              ? lang === "zh-cn"
                ? "设计文档"
                : "Design Document Slides"
              : ui('game.screenshots', lang)}
          </h2>
          {game.slug === "elemental-realm" ? (
            <ImageCarousel
              client:visible
              images={game.gallery}
              altPrefix={`${titleEN} slide`}
            />
          ) : (
            <ImageGallery
              client:visible
              images={game.gallery}
              altPrefix={`${titleEN} screenshot`}
              layout="grid"
              columns={3}
            />
          )}
        </section>
      )
    }

    {/* ═══════ Project Details ═══════ */}

    {/* tech-docs (Echo Quest) → CTA button linking to Starlight docs */}
    {
      techDocsHref && (
        <section>
          <hr class="border-[var(--color-border)] mb-8" />
          <h2 class="text-xl font-semibold text-[var(--color-text)] mb-4">
            {ui('game.projectDetails', lang)}
          </h2>
          <p class="text-[var(--color-text-secondary)] text-sm mb-6">
            {lang === "zh-cn"
              ? "本项目包含详细的技术文档，涵盖 GAS 系统、战斗系统、打击反馈、动画系统、Motion Warping 和敌人 AI。"
              : "This project includes comprehensive technical documentation covering the GAS system, combat systems, hit feedback, animation, motion warping, and enemy AI."}
          </p>
          <a
            href={techDocsHref}
            class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white text-sm font-medium rounded-lg transition-colors"
          >
            📖 {lang === "zh-cn" ? "查看技术文档" : "View Tech Docs"}
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"
              />
            </svg>
          </a>
        </section>
      )
    }

    {/* key-features → inline MDX content (no redirect) */}
    {
      DetailsContent && (
        <section>
          <hr class="border-[var(--color-border)] mb-8" />
          <div
            class="prose prose-sm sm:prose-base max-w-none
                    prose-headings:text-[var(--color-text)] prose-headings:font-semibold
                    prose-h1:text-2xl prose-h1:mt-0 prose-h1:mb-4
                    prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:border-b prose-h2:border-[var(--color-border)] prose-h2:pb-2
                    prose-p:text-[var(--color-text-secondary)] prose-p:leading-relaxed
                    prose-strong:text-[var(--color-text)]
                    prose-a:text-[var(--color-accent)] hover:prose-a:text-[var(--color-accent-hover)]
                    prose-li:text-[var(--color-text-secondary)]
                    prose-ul:my-3 prose-ol:my-3"
          >
            <DetailsContent />
          </div>
        </section>
      )
    }

    {/* ═══════ Back to games ═══════ */}
    <div class="pt-4">
      <a
        href={getLocalizedPath("/games/", lang)}
        class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 19l-7-7 7-7"></path>
        </svg>
        {ui('game.backToGames', lang)}
      </a>
    </div>
  </div>
  </div>
</BaseLayout>

<script>
  function initCinematicHero() {
    const section = document.getElementById("cinematic-hero");
    const bgLayer = document.getElementById("cinematic-hero-bg");
    if (!section || !bgLayer) return;

    function update() {
      const rect = section.getBoundingClientRect();
      const heroH = section.offsetHeight;
      const scrolledPast = -rect.top;

      if (rect.bottom <= 0) {
        bgLayer.style.cssText = "position:absolute;opacity:0;";
      } else {
        bgLayer.style.position = "fixed";
        bgLayer.style.top = "0";
        bgLayer.style.left = "0";
        bgLayer.style.width = "100%";
        bgLayer.style.height = `${heroH}px`;
        bgLayer.style.zIndex = "0";
        const fade = Math.max(0, scrolledPast) / (heroH * 0.65);
        bgLayer.style.opacity = String(Math.max(0, 1 - fade));
      }
    }

    window.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", update, { passive: true });
    update();

    document.addEventListener(
      "astro:before-swap",
      () => {
        window.removeEventListener("scroll", update);
        window.removeEventListener("resize", update);
        bgLayer.style.cssText = "";
      },
      { once: true }
    );
  }

  initCinematicHero();
  document.addEventListener("astro:after-swap", initCinematicHero);
</script>
